          e.symm (DirectSum.of _ i (v ÔŐŚÔéť[k] l)) = l v := by
  haveI := symGroupImage_isSemisimpleRing k V n
  haveI := symGroupImage_faithfulSMul k V n hN
  exact Theorem5_18_1_bimodule_decomposition_explicit k (TensorPower k V n)
