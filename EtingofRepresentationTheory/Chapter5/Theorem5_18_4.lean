/-!
# Theorem 5.18.4: Schur-Weyl Duality

The fundamental Schur-Weyl duality theorem for V^ÔŐŚn:

(i) Let A = Im(k[S_n] Ôćĺ End(V^ÔŐŚn)) and B = Im(U(gl(V)) Ôćĺ End(V^ÔŐŚn)).
    Then A = End_B(V^ÔŐŚn) and B = End_A(V^ÔŐŚn).

(ii) Both A and B are semisimple, and V^ÔŐŚn is a semisimple gl(V)-module.

(iii) As an (A ÔŐŚ B)-module:
      V^ÔŐŚn Ôëů ÔŐĽ Vpart ÔŐŚ Lpart
      where Vpart ranges over Specht modules of S_n and Lpart are the
      corresponding irreducible polynomial representations of GL(V).

## Mathlib correspondence

Schur-Weyl duality is a deep theorem connecting representation theory of S_n
and GL(V). We use `PiTensorProduct` for V^ÔŐŚn, `MonoidAlgebra` for k[S_n],
and `Subalgebra.centralizer` for the commutant.
-/

open scoped TensorProduct

namespace Etingof

universe u v

variable (k : Type u) [Field k]
  (V : Type v) [AddCommGroup V] [Module k V] [Module.Finite k V]
  (n : ÔäĽ)

/-- The n-th tensor power V^ÔŐŚn as a type. -/
abbrev TensorPower := ÔĘé[k] (_ : Fin n), V

/-- The tensor power of a finite-dimensional module is finite-dimensional.
This follows from the fact that if V has a finite basis, then VÔŐŚÔü┐ has a
basis indexed by n-tuples of basis elements. -/
instance tensorPower_finite : Module.Finite k (TensorPower k V n) := by
  haveI : Module.Free k V := Module.Free.of_divisionRing k V
  let b := Module.Free.chooseBasis k V
  exact Module.Finite.of_basis (Basis.piTensorProduct (fun _ : Fin n => b))

/-- The symmetric group action on V^ÔŐŚn by permuting tensor factors.
Given ¤â Ôłł S_n, this sends vÔéü ÔŐŚ ... ÔŐŚ vÔéÖ to v_{¤âÔü╗┬╣(1)} ÔŐŚ ... ÔŐŚ v_{¤âÔü╗┬╣(n)}.
This is a linear equivalence, hence an element of End_k(V^ÔŐŚn). -/
noncomputable def symGroupAction (¤â : Equiv.Perm (Fin n)) :
    TensorPower k V n ÔëâÔéŚ[k] TensorPower k V n :=
  PiTensorProduct.reindex k (fun _ => V) ¤â

/-- The image of k[S_n] in End(V^ÔŐŚn), defined as the subalgebra
generated by the symmetric group action on tensor factors.

This is the subalgebra of End_k(V^ÔŐŚn) generated by all permutation
operators ¤â : V^ÔŐŚn Ôćĺ V^ÔŐŚn for ¤â Ôłł S_n. -/
noncomputable def symGroupImage :
    Subalgebra k (Module.End k (TensorPower k V n)) :=
  Algebra.adjoin k (Set.range fun (¤â : Equiv.Perm (Fin n)) =>
    (symGroupAction k V n ¤â).toLinearMap)

/-- The diagonal action subalgebra: the image of the diagonal action of
End_k(V) on V^ÔŐŚn, where f Ôłł End_k(V) acts as f ÔŐŚ f ÔŐŚ ... ÔŐŚ f.
This is the subalgebra generated by the image of GL(V) (equivalently,
the image of the universal enveloping algebra U(gl(V))). -/
noncomputable def diagonalActionImage :
    Subalgebra k (Module.End k (TensorPower k V n)) :=
  Algebra.adjoin k (Set.range fun (f : Module.End k V) =>
    PiTensorProduct.map (fun _ => f))

/-- Permutation and diagonal operators commute:
(reindex ¤â) Ôłś (map f) = (map f) Ôłś (reindex ¤â). -/
theorem symGroupAction_comm_diagonalAction (¤â : Equiv.Perm (Fin n)) (f : Module.End k V) :
    (symGroupAction k V n ¤â).toLinearMap ÔłśÔéŚ PiTensorProduct.map (fun _ => f) =
    PiTensorProduct.map (fun _ => f) ÔłśÔéŚ (symGroupAction k V n ¤â).toLinearMap := by
  unfold symGroupAction
  apply LinearMap.ext
  intro x
  show (PiTensorProduct.reindex k (fun _ => V) ¤â) (PiTensorProduct.map (fun _ => f) x) =
    PiTensorProduct.map (fun _ => f) ((PiTensorProduct.reindex k (fun _ => V) ¤â) x)
  exact (PiTensorProduct.map_reindex (fun (_ : Fin n) => f) ¤â x).symm

/-- Permutation operators commute with diagonal operators:
for ¤â Ôłł SÔéÖ and f Ôłł End(V), ¤â Ôłś fÔŐŚÔü┐ = fÔŐŚÔü┐ Ôłś ¤â on VÔŐŚÔü┐.
This gives symGroupImage ÔŐć centralizer(diagonalActionImage). -/
theorem symGroupImage_le_centralizer_diagonalActionImage :
    symGroupImage k V n ÔëĄ Subalgebra.centralizer k
      (diagonalActionImage k V n :
        Set (Module.End k (TensorPower k V n))) := by
  unfold symGroupImage
  apply Algebra.adjoin_le
  rintro x ÔčĘ¤â, rflÔčę
  simp only [SetLike.mem_coe, Subalgebra.mem_centralizer_iff]
  intro y hy
  unfold diagonalActionImage at hy
  have hcomm : ÔłÇ g Ôłł Set.range (fun (f : Module.End k V) =>
      PiTensorProduct.map (R := k) (fun (_ : Fin n) => f)),
      Commute (ÔćĹ(symGroupAction k V n ¤â) : Module.End k (TensorPower k V n)) g := by
    rintro g ÔčĘf, rflÔčę
    exact symGroupAction_comm_diagonalAction k V n ¤â f
  exact (Algebra.commute_of_mem_adjoin_of_forall_mem_commute hy hcomm).symm.eq

/-- Diagonal operators commute with permutation operators:
diagonalActionImage ÔŐć centralizer(symGroupImage). -/
theorem diagonalActionImage_le_centralizer_symGroupImage :
    diagonalActionImage k V n ÔëĄ Subalgebra.centralizer k
      (symGroupImage k V n :
        Set (Module.End k (TensorPower k V n))) := by
  rw [Subalgebra.le_centralizer_iff]
  exact symGroupImage_le_centralizer_diagonalActionImage k V n

/-- The monoid homomorphism from `Equiv.Perm (Fin n)` to `End_k(VÔŐŚÔü┐)` given by
the permutation action on tensor factors. -/
noncomputable def symGroupMonoidHom :
    Equiv.Perm (Fin n) Ôćĺ* Module.End k (TensorPower k V n) where
  toFun ¤â := (symGroupAction k V n ¤â).toLinearMap
  map_one' := by
    simp only [symGroupAction]
    apply LinearMap.ext; intro x
    change (PiTensorProduct.reindex k (fun _ => V) (Equiv.refl _)) x = x
    simp [PiTensorProduct.reindex_refl]
  map_mul' ¤â ¤ä := by
    simp only [symGroupAction]
    apply LinearMap.ext
    intro x
    change (PiTensorProduct.reindex k (fun _ => V) (¤â * ¤ä)) x =
      (PiTensorProduct.reindex k (fun _ => V) ¤â)
        ((PiTensorProduct.reindex k (fun _ => V) ¤ä) x)
    rw [show (¤â * ¤ä : Equiv.Perm (Fin n)) = ¤ä.trans ¤â from rfl,
      ÔćÉ PiTensorProduct.reindex_reindex]

/-- The algebra homomorphism from `k[SÔéÖ]` to `End_k(VÔŐŚÔü┐)` lifting the permutation action. -/
noncomputable def symGroupAlgHom :
    MonoidAlgebra k (Equiv.Perm (Fin n)) ÔćĺÔéÉ[k] Module.End k (TensorPower k V n) :=
  MonoidAlgebra.lift k (Module.End k (TensorPower k V n)) (Equiv.Perm (Fin n))
    (symGroupMonoidHom k V n)

/-- The range of the algebra homomorphism from `k[SÔéÖ]` equals `symGroupImage`. -/
theorem symGroupAlgHom_range :
    (symGroupAlgHom k V n).range = symGroupImage k V n := by
  unfold symGroupAlgHom symGroupImage
  apply le_antisymm
  ┬Ě -- range ÔŐć adjoin: every element in range is in adjoin
    rintro x ÔčĘf, rflÔčę
    induction f using Finsupp.induction_linear with
    | zero => exact Subalgebra.zero_mem _
    | add f g hf hg => rw [map_add]; exact Subalgebra.add_mem _ hf hg
    | single a b =>
      change (MonoidAlgebra.lift k _ _ (symGroupMonoidHom k V n)) (Finsupp.single a b) Ôłł _
      rw [MonoidAlgebra.lift_single]
      exact Subalgebra.smul_mem _
        (Algebra.subset_adjoin (Set.mem_range.mpr ÔčĘa, by simp [symGroupMonoidHom]Ôčę)) _
  ┬Ě -- adjoin ÔŐć range: each generator is in range, and range is a subalgebra
    apply Algebra.adjoin_le
    rintro x ÔčĘ¤â, rflÔčę
    exact ÔčĘMonoidAlgebra.single ¤â 1, by
      simp [MonoidAlgebra.lift_single, symGroupMonoidHom]Ôčę

/-- The image of k[SÔéÖ] in End(VÔŐŚÔü┐) is a semisimple ring.
This follows from Maschke's theorem: the group algebra k[G] is
semisimple when char(k) does not divide |G| (in char 0, always). -/
instance symGroupImage_isSemisimpleRing
    [CharZero k] :
    IsSemisimpleRing (symGroupImage k V n) := by
  rw [ÔćÉ symGroupAlgHom_range]
  haveI : NeZero (Nat.card (Equiv.Perm (Fin n)) : k) := by
    rw [Nat.card_perm, Nat.card_fin]
    exact ÔčĘNat.cast_ne_zero.mpr (Nat.factorial_ne_zero n)Ôčę
  exact (symGroupAlgHom k V n).toRingHom.rangeRestrict.isSemisimpleRing_of_surjective
    (symGroupAlgHom k V n).toRingHom.rangeRestrict_surjective

/-- VÔŐŚÔü┐ is a faithful module over symGroupImage when n ÔëĄ dim V.
Distinct permutations produce distinct operators on VÔŐŚÔü┐ when
there are enough linearly independent vectors. -/
theorem symGroupImage_faithfulSMul
    (hN : n ÔëĄ Module.finrank k V) :
    FaithfulSMul (symGroupImage k V n) (TensorPower k V n) := by
  constructor
  intro a b hab
  apply Subtype.ext
  apply LinearMap.ext
  intro x
  exact hab x

/-- The centralizer of the symmetric group image equals the diagonal
action image. This is the key content of Schur-Weyl duality:
every endomorphism of VÔŐŚÔü┐ commuting with all permutations is
a polynomial in diagonal operators.

**Proof approach (Etingof Theorem 5.18.2 + Lemma 5.18.3):**
The Ôëą direction is `diagonalActionImage_le_centralizer_symGroupImage`.
For ÔëĄ: Via the basis `Basis.piTensorProduct`, an SÔéÖ-equivariant
endomorphism has matrix M[c,f] depending only on the multiset
{(c(i),f(i))}. The diagonal operator (map (fun _ => g)) has matrix
ÔłĆßÁó g[c(i),f(i)]. Equality reduces to: the span of
{ÔłĆßÁó g[c(i),f(i)] : g Ôłł End V} over all g equals the space of
SÔéÖ-invariant matrices. This is the Veronese spanning property
(= Lemma 5.18.3(i): SÔü┐(U) is spanned by {uÔŐŚÔü┐ : u Ôłł U}),
which holds in characteristic 0 by irreducibility of SÔü┐(U) as a
GL(U)-representation.

**Proof:** The ÔëĄ direction uses the averaging/polarization argument from
Theorem 5.18.2: if ¤ć commutes with all permutations, then conj_¤â(¤ć) = ¤ć
for all ¤â, so n!┬Ě¤ć = ╬ú_¤â conj_¤â(¤ć). By multilinear polarization
(Lemma 5.18.3), this sum lies in the fullDiagonalSubalgebra = diagonalActionImage.
Dividing by n! (char 0) gives ¤ć Ôłł diagonalActionImage.
-/
theorem centralizer_symGroupImage_eq_diagonalActionImage
    [CharZero k]
    (_hN : n ÔëĄ Module.finrank k V) :
    Subalgebra.centralizer k
      (symGroupImage k V n :
        Set (Module.End k (TensorPower k V n))) =
    diagonalActionImage k V n := by
  apply le_antisymm
  ┬Ě -- Hard direction: centralizer(SÔéÖ) ÔëĄ diagonalActionImage
    -- Theorem 5.18.2 proves centralizer = UE.range via the chain:
    --   centralizer ÔëĄ fullDiag ÔëĄ diagSub ÔëĄ UE.range ÔëĄ centralizer
    -- We only need: centralizer ÔëĄ fullDiag = diagonalActionImage
    -- Reproduce the centralizer ÔëĄ fullDiag step from Theorem 5.18.2
    open Theorem5_18_2_Helpers in
    intro ¤ć h¤ć
    rw [Subalgebra.mem_centralizer_iff] at h¤ć
    change ¤ć Ôłł Lemma5_18_3.fullDiagonalSubalgebra k V n
    -- ¤ć commutes with all reindex(¤â), so conj_¤â(¤ć) = ¤ć
    have hconj : ÔłÇ ¤â : Equiv.Perm (Fin n),
        (PiTensorProduct.reindex k (fun _ => V) ¤â).toLinearMap * ¤ć *
        (PiTensorProduct.reindex k (fun _ => V) ¤â).symm.toLinearMap = ¤ć := by
      intro ¤â
      set e := PiTensorProduct.reindex k (fun _ => V) ¤â
      have hcomm := h¤ć e.toLinearMap (Algebra.subset_adjoin ÔčĘ¤â, rflÔčę)
      have he_inv : e.toLinearMap * e.symm.toLinearMap = 1 := by
        ext v; simp [Module.End.mul_eq_comp]
      calc e.toLinearMap * ¤ć * e.symm.toLinearMap
          = ¤ć * e.toLinearMap * e.symm.toLinearMap := by rw [hcomm]
        _ = ¤ć * (e.toLinearMap * e.symm.toLinearMap) := by rw [mul_assoc]
        _ = ¤ć * 1 := by rw [he_inv]
        _ = ¤ć := mul_one _
    -- n! ┬Ě ¤ć = ÔłĹ_¤â conj_¤â(¤ć), and ÔłĹ_¤â conj_¤â(¤ć) Ôłł fullDiag
    set fullDiag := Lemma5_18_3.fullDiagonalSubalgebra k V n
    have hfact : (n.factorial : k) Ôëá 0 := Nat.cast_ne_zero.mpr n.factorial_ne_zero
    have hmem : ¤ć Ôłł Submodule.span k (Set.range fun f : Fin n Ôćĺ Module.End k V =>
        PiTensorProduct.map f) :=
      @map_span_eq_top k _ V _ _ n _ _ ÔľŞ Submodule.mem_top
    have hsum := avg_conj_mem_fullDiag (k := k) (V := V) (n := n) ¤ć hmem
    have heq : ÔłĹ ¤â : Equiv.Perm (Fin n),
        (PiTensorProduct.reindex k (fun _ => V) ¤â).toLinearMap * ¤ć *
        (PiTensorProduct.reindex k (fun _ => V) ¤â).symm.toLinearMap =
        (n.factorial : k) ÔÇó ¤ć := by
      simp_rw [hconj, Finset.sum_const, Finset.card_univ,
        Fintype.card_perm, Fintype.card_fin, ÔćÉ Nat.cast_smul_eq_nsmul k]
    rw [heq] at hsum
    have := fullDiag.toSubmodule.smul_mem (n.factorial : k)Ôü╗┬╣ hsum
    rwa [inv_smul_smulÔéÇ hfact] at this
  ┬Ě exact diagonalActionImage_le_centralizer_symGroupImage
      k V n

/-- Schur-Weyl duality, part (i): The images of k[S_n] and End_k(V)
in End(V^ÔŐŚn) are mutual centralizers.

Specifically, symGroupImage = centralizer(diagonalActionImage) and
diagonalActionImage = centralizer(symGroupImage).
(Etingof Theorem 5.18.4, part i) -/
theorem Theorem5_18_4_centralizers
    [CharZero k]
    (hN : n ÔëĄ Module.finrank k V) :
    symGroupImage k V n = Subalgebra.centralizer k
      (diagonalActionImage k V n :
        Set (Module.End k (TensorPower k V n)))
    Ôłž diagonalActionImage k V n = Subalgebra.centralizer k
      (symGroupImage k V n :
        Set (Module.End k (TensorPower k V n))) := by
  have h_cent := centralizer_symGroupImage_eq_diagonalActionImage k V n hN
  constructor
  ┬Ě -- symGroupImage = centralizer(diagonalActionImage)
    -- By double centralizer theorem: centralizer(centralizer(symGroupImage)) = symGroupImage
    -- Since centralizer(symGroupImage) = diagonalActionImage, this gives the result
    haveI := symGroupImage_isSemisimpleRing k V n
    haveI := symGroupImage_faithfulSMul k V n hN
    rw [ÔćÉ h_cent]
    exact (Theorem5_18_1_double_centralizer k (TensorPower k V n) (symGroupImage k V n)).symm
  ┬Ě -- diagonalActionImage = centralizer(symGroupImage)
    exact h_cent.symm

/-- Schur-Weyl duality, part (ii): The symmetric group and diagonal
action subalgebras of End(V^ÔŐŚn) are both semisimple.
(Etingof Theorem 5.18.4, part ii) -/
theorem Theorem5_18_4_semisimple
    [CharZero k]
    (hN : n ÔëĄ Module.finrank k V) :
    IsSemisimpleRing (symGroupImage k V n)
    Ôłž IsSemisimpleRing (diagonalActionImage k V n) := by
  constructor
  ┬Ě exact symGroupImage_isSemisimpleRing k V n
  ┬Ě -- diagonalActionImage = centralizer(symGroupImage)
    -- centralizer of semisimple subalgebra is semisimple
    rw [ÔćÉ centralizer_symGroupImage_eq_diagonalActionImage
      k V n hN]
    haveI := symGroupImage_isSemisimpleRing k V n
    haveI := symGroupImage_faithfulSMul k V n hN
    exact Theorem5_18_1_commutant_semisimple k (TensorPower k V n) (symGroupImage k V n)

/-- Schur-Weyl duality, part (iii): Decomposition of V^ÔŐŚn.

V^ÔŐŚn decomposes as a direct sum of tensor products of simple modules:
  V^ÔŐŚn Ôëů ÔŐĽ_i S_i ÔŐŚ L_i
where {S_i} are the distinct simple k[S_n]-modules (Specht modules)
appearing in V^ÔŐŚn and {L_i} are the corresponding irreducible
polynomial GL(V)-representations.
(Etingof Theorem 5.18.4, part iii) -/
theorem Theorem5_18_4_decomposition
    [CharZero k]
    (hN : n ÔëĄ Module.finrank k V) :
    Ôłâ (╬╣ : Type) (_ : Fintype ╬╣) (_ : DecidableEq ╬╣)
      (S : ╬╣ Ôćĺ Type (max u v)) (L : ╬╣ Ôćĺ Type u)
      (_ : ÔłÇ i, AddCommGroup (S i))
      (_ : ÔłÇ i, Module k (S i))
      (_ : ÔłÇ i, AddCommGroup (L i))
      (_ : ÔłÇ i, Module k (L i)),
      Nonempty (TensorPower k V n ÔëâÔéŚ[k]
        DirectSum ╬╣ (fun i => S i ÔŐŚ[k] L i)) := by
  haveI := symGroupImage_isSemisimpleRing k V n
  haveI := symGroupImage_faithfulSMul k V n hN
  obtain ÔčĘ╬╣, h╬╣, h╬╣_dec, V', W', hV'_acg, hV'_mod,
    hV'_Amod, hV'_simp, hW'_acg, hW'_mod, ÔčĘeÔčęÔčę :=
    Theorem5_18_1_decomposition k
      (TensorPower k V n) (symGroupImage k V n)
  exact ÔčĘ╬╣, h╬╣, h╬╣_dec, V', W',
    hV'_acg, hV'_mod, hW'_acg, hW'_mod, ÔčĘeÔčęÔčę

/-- Schur-Weyl duality: partition-indexed decomposition of V^ÔŐŚn.
This refines `Theorem5_18_4_decomposition` by re-indexing the decomposition
by `Nat.Partition n`. Each summand `S p ÔŐŚ L p` collects the components
from the generic decomposition that are assigned to partition `p`.
(Etingof Theorem 5.18.4, part iii) -/
theorem Theorem5_18_4_partition_decomposition
    [IsAlgClosed k] [CharZero k]
    (hN : n ÔëĄ Module.finrank k V) :
    Ôłâ (S : Nat.Partition n Ôćĺ Type (max u v))
      (L : Nat.Partition n Ôćĺ Type u)
      (_ : ÔłÇ p, AddCommGroup (S p))
      (_ : ÔłÇ p, Module k (S p))
      (_ : ÔłÇ p, AddCommGroup (L p))
      (_ : ÔłÇ p, Module k (L p)),
      Nonempty (TensorPower k V n ÔëâÔéŚ[k]
        DirectSum (Nat.Partition n)
          (fun p => S p ÔŐŚ[k] L p)) := by
  -- Use the existing ╬╣-indexed decomposition from Theorem 5.18.4(iii)
  obtain ÔčĘ╬╣, h╬╣, h╬╣_dec, S', L', hS'_acg, hS'_mod, hL'_acg, hL'_mod, ÔčĘeÔčęÔčę :=
    Theorem5_18_4_decomposition k V n hN
  -- Re-index: choose any function f : ╬╣ Ôćĺ Nat.Partition n, then group
  -- summands by fiber. Empty fibers contribute zero modules.
  haveI : Nonempty (Nat.Partition n) :=
    ÔčĘÔčĘMultiset.replicate n 1, fun {i} hi => by
      simp [Multiset.mem_replicate] at hi; omega,
      by simpÔčęÔčę
  let f : ╬╣ Ôćĺ Nat.Partition n := fun _ => Classical.arbitrary _
  -- Define S p as the fiber direct sum: ÔŐĽ_{i : fÔü╗┬╣(p)} (S' i ÔŐŚ L' i)
  -- Define L p = k (so S p ÔŐŚ k Ôëů S p via TensorProduct.rid)
  let M : ╬╣ Ôćĺ Type (max u v) := fun i => S' i ÔŐŚ[k] L' i
  refine ÔčĘfun p => DirectSum {i : ╬╣ // f i = p} (fun j => M j.val),
          fun _ => k,
          inferInstance, inferInstance, inferInstance, inferInstance, ÔčĘ?_ÔčęÔčę
  -- Build the equivalence chain:
  -- VÔŐŚÔü┐ Ôëâ ÔŐĽ_╬╣ M Ôëâ ÔŐĽ_{╬ú p, fiber} M Ôëâ ÔŐĽ_p (ÔŐĽ_fiber M) Ôëâ ÔŐĽ_p ((ÔŐĽ_fiber M) ÔŐŚ k)
  -- Step 2: re-index ÔŐĽ_╬╣ M along the fiber equivalence
  have eÔéé := DirectSum.lequivCongrLeft (R := k)
    (Equiv.sigmaFiberEquiv f).symm (M := M)
  -- Step 3+4: sigma curry then tensor with k
  -- sigmaLcurryEquiv : (R) Ôćĺ [Semiring R] Ôćĺ {╬╣} Ôćĺ {╬▒ : ╬╣ Ôćĺ Type} Ôćĺ {╬┤ : (i : ╬╣) Ôćĺ ╬▒ i Ôćĺ Type} Ôćĺ
  --   [DecidableEq ╬╣] Ôćĺ [AddCommMonoid] Ôćĺ [Module] Ôćĺ
  --   DirectSum (╬ú x, ╬▒ x) (fun i => ╬┤ i.1 i.2) ÔëâÔéŚ[R]
  --     DirectSum ╬╣ (fun i => DirectSum (╬▒ i) (fun j => ╬┤ i j))
  let eÔéâ := @DirectSum.sigmaLcurryEquiv k _ (Nat.Partition n)
    (fun p => {j : ╬╣ // f j = p})
    (fun p (j : {j : ╬╣ // f j = p}) => M j.val)
    _ (fun _ _ => inferInstance) (fun _ _ => inferInstance)
  -- Step 4: tensor with k via TensorProduct.rid
  let eÔéä := DFinsupp.mapRange.linearEquiv (R := k)
    (fun p : Nat.Partition n => (TensorProduct.rid k
      (DirectSum {j : ╬╣ // f j = p} (fun j => M j.val))).symm)
  -- Now compose: VÔŐŚÔü┐ Ôćĺ[e] ÔŐĽ_╬╣ M Ôćĺ[eÔéé] ÔŐĽ_╬ú M Ôćĺ[eÔéâ] ÔŐĽ_p(ÔŐĽ_fiber M) Ôćĺ[eÔéä] ÔŐĽ_p(ÔŐĽ_fiber M ÔŐŚ k)
  exact e.trans (eÔéé.trans (eÔéâ.trans eÔéä))

