/-- Schur-Weyl duality, part (iii), GL_N representation form, explicit
version.

Strengthens `Theorem5_18_4_GL_rep_decomposition` by concretizing the
summand types and producing an explicit iso whose inverse on pure
tensors is the evaluation map:

* `S i : Submodule (symGroupImage k V n) (V^‚äón)` (Specht-module realisations
  as concrete submodules);
* `L i : FDRep k (GL_N k)` whose carrier is
  `‚Ü•(S i) ‚Üí‚āó[symGroupImage k V n] V^‚äón`, with the `GL_N`-action given by
  post-composition with `g ‚Ü¶ g^{‚äón}` (which lies in
  `centralizer(symGroupImage)` by the centralizer identity);
* a `k`-linear iso `L_carrier i : (L i : Type u) ‚ČÉ‚āó[k]
  (‚Ü•(S i) ‚Üí‚āó[symGroupImage k V n] V^‚äón)` identifying the bundled FDRep
  carrier with the explicit hom-space (it is `LinearEquiv.refl` after
  the `FGModuleCat.of_carrier` defeq);
* explicit iso `e : V^‚äón ‚ČÉ‚āó[k] ‚®ĀŠĶĘ ‚Ü•(S i) ‚äó[k] (L i : Type u)` whose
  inverse on pure tensors is the evaluation map:
  `e.symm (of i (v ‚äó‚āú l)) = (L_carrier i l) v`.

The `L_carrier` clause sidesteps a defeq fragility: when stating the
existential, `(L i : Type u)` is universally quantified and not yet
concretised, so an `l : (L i : Type u)` cannot be applied to `v` as a
linear map without the explicit identification with `‚Ü•(S i) ‚Üí‚āó[A] E`.

This is the form required by the `GL_N`-equivariance argument
(`glTensorRep_equivariant_schurWeyl_decomposition`,
issue #2540): the evaluation formula together with the post-composition
`GL_N`-action on each `L i` makes equivariance computable on pure
tensors. -/
theorem Theorem5_18_4_GL_rep_decomposition_explicit
    (k : Type u) [Field k] [IsAlgClosed k] [CharZero k]
    (N n : ‚Ąē) (hN : n ‚Č§ N) :
    ‚ąÉ (őĻ : Type) (_ : Fintype őĻ) (_ : DecidableEq őĻ)
      (S : őĻ ‚Üí Submodule (symGroupImage k (Fin N ‚Üí k) n)
        (TensorPower k (Fin N ‚Üí k) n))
      (_ : ‚ąÄ i, IsSimpleModule (symGroupImage k (Fin N ‚Üí k) n) (S i))
      (_ : ‚ąÄ i j,
        Nonempty (‚Ü•(S i) ‚ČÉ‚āó[symGroupImage k (Fin N ‚Üí k) n] ‚Ü•(S j)) ‚Üí i = j)
      (L : őĻ ‚Üí FDRep k (Matrix.GeneralLinearGroup (Fin N) k))
      (L_carrier : ‚ąÄ i, (L i : Type u) ‚ČÉ‚āó[k]
        (‚Ü•(S i) ‚Üí‚āó[symGroupImage k (Fin N ‚Üí k) n]
          TensorPower k (Fin N ‚Üí k) n)),
      ‚ąÉ (e : TensorPower k (Fin N ‚Üí k) n ‚ČÉ‚āó[k]
          DirectSum őĻ (fun i => ‚Ü•(S i) ‚äó[k] (L i : Type u))),
        ‚ąÄ (i : őĻ) (v : ‚Ü•(S i)) (l : (L i : Type u)),
          e.symm (DirectSum.of (fun i => ‚Ü•(S i) ‚äó[k] (L i : Type u)) i
              (v ‚äó‚āú[k] l)) = (L_carrier i l) v := by
  set V : Type u := Fin N ‚Üí k with hV
  haveI : Module.Finite k V := inferInstance
  have hfinrank : Module.finrank k V = N :=
    (Module.finrank_pi k).trans (Fintype.card_fin N)
  have hN' : n ‚Č§ Module.finrank k V := hfinrank.symm ‚Ėł hN
  haveI := symGroupImage_isSemisimpleRing k V n
  haveI := symGroupImage_faithfulSMul k V n hN'
  -- Get the explicit bimodule decomposition with concrete summand types
  -- and the evaluation formula.
  obtain ‚ü®őĻ, hőĻ, hőĻ_dec, S', hS'_simp, hS'_dist, e, he‚ü© :=
    Theorem5_18_4_bimodule_decomposition_explicit k V n hN'
  -- Centralizer identity: centralizer(symGroupImage) = diagonalActionImage.
  have h_eq : Subalgebra.centralizer k
      (symGroupImage k V n : Set (Module.End k (TensorPower k V n))) =
        diagonalActionImage k V n :=
    (Theorem5_18_4_centralizers k V n hN').2.symm
  -- Monoid hom GL_N ‚Üí centralizer(symGroupImage), same as in
  -- `_GL_rep_decomposition`.
  let glHom : Matrix.GeneralLinearGroup (Fin N) k ‚Üí*
      ‚Ü•(Subalgebra.centralizer k
        (symGroupImage k V n : Set (Module.End k (TensorPower k V n)))) :=
  { toFun := fun g => ‚ü®PiTensorProduct.map
        (fun _ : Fin n => Matrix.mulVecLin (R := k) g.val), by
      rw [h_eq]
      exact Algebra.subset_adjoin ‚ü®Matrix.mulVecLin g.val, rfl‚ü©‚ü©
    map_one' := by
      apply Subtype.ext
      change PiTensorProduct.map
          (fun _ : Fin n => Matrix.mulVecLin (R := k) (1 : Matrix _ _ k)) = 1
      have : (fun _ : Fin n => Matrix.mulVecLin (R := k) (1 : Matrix _ _ k)) =
          (fun _ : Fin n => (LinearMap.id : V ‚Üí‚āó[k] V)) :=
        funext fun _ => Matrix.mulVecLin_one
      rw [this, PiTensorProduct.map_id]; rfl
    map_mul' := fun g‚āĀ g‚āā => by
      apply Subtype.ext
      change PiTensorProduct.map
          (fun _ : Fin n => Matrix.mulVecLin (R := k) (g‚āĀ.val * g‚āā.val)) =
        PiTensorProduct.map
            (fun _ : Fin n => Matrix.mulVecLin (R := k) g‚āĀ.val) *
          PiTensorProduct.map
            (fun _ : Fin n => Matrix.mulVecLin (R := k) g‚āā.val)
      have : (fun _ : Fin n => Matrix.mulVecLin (R := k) (g‚āĀ.val * g‚āā.val)) =
          (fun _ : Fin n => (Matrix.mulVecLin g‚āĀ.val).comp
            (Matrix.mulVecLin g‚āā.val)) :=
        funext fun _ => Matrix.mulVecLin_mul g‚āĀ.val g‚āā.val
      rw [this, PiTensorProduct.map_comp]; rfl }
  -- Each `‚Ü•(S' i)` is a finite-dimensional `k`-vector space (it injects into
  -- the finite-dimensional `TensorPower k V n` via the subtype map).
  haveI hSi_fin : ‚ąÄ i, Module.Finite k ((‚Ü•(S' i) : Type u)) := fun i =>
    Module.Finite.of_injective ((S' i).subtype.restrictScalars k)
      Subtype.val_injective
  -- The `A`-linear hom space `‚Ü•(S' i) ‚Üí‚āó[A] E` is finite-dimensional over `k`
  -- because it injects (`k`-linearly) into the `k`-linear hom space, which has
  -- dimension `dim(‚Ü•(S' i)) ¬∑ dim(E)`. (Same derivation as in
  -- `glTensorRep_equivariant_schurWeyl_decomposition`.)
  haveI hLi_fin : ‚ąÄ i, Module.Finite k
      ((‚Ü•(S' i) : Type u) ‚Üí‚āó[symGroupImage k V n] TensorPower k V n) :=
    fun i => by
      haveI : Module.Finite k (‚Ü•(S' i) : Type u) := hSi_fin i
      haveI : Module.Free k (‚Ü•(S' i) : Type u) :=
        Module.Free.of_divisionRing k (‚Ü•(S' i))
      haveI : Module.Finite k
          ((‚Ü•(S' i) : Type u) ‚Üí‚āó[k] TensorPower k V n) :=
        Module.Finite.linearMap k k (‚Ü•(S' i)) (TensorPower k V n)
      exact Module.Finite.of_injective
        (LinearMap.restrictScalars‚āó k (symGroupImage k V n) (‚Ü•(S' i))
          (TensorPower k V n) k)
        (LinearMap.restrictScalars_injective _)
  -- For each i, build the GL_N representation on `‚Ü•(S' i) ‚Üí‚āó[A] E` directly:
  -- `g ¬∑ l := (centralizerToEndA (glHom g)).comp l`. Manual construction
  -- bypasses an instance-synthesis diamond on the centralizer-Module
  -- structure of the hom-space. (Same construction as in
  -- `glTensorRep_equivariant_schurWeyl_decomposition`.)
  let ŌĀ : ‚ąÄ i, Matrix.GeneralLinearGroup (Fin N) k ‚Üí*
      Module.End k (‚Ü•(S' i) ‚Üí‚āó[symGroupImage k V n] TensorPower k V n) := fun i =>
  { toFun := fun g =>
    { toFun := fun l =>
        (centralizerToEndA k (TensorPower k V n) (symGroupImage k V n)
          (glHom g)).comp l
      map_add' := fun l‚āĀ l‚āā => by
        ext v
        simp only [LinearMap.comp_apply, LinearMap.add_apply, map_add]
      map_smul' := fun c l => by
        ext v
        simp only [LinearMap.smul_apply, RingHom.id_apply,
          LinearMap.comp_apply, LinearMap.map_smul_of_tower] }
    map_one' := by
      ext l v
      simp only [LinearMap.coe_mk, AddHom.coe_mk, LinearMap.comp_apply,
        Module.End.one_apply]
      change (centralizerToEndA k (TensorPower k V n) (symGroupImage k V n)
        (glHom 1)) (l v) = l v
      rw [map_one, map_one]; rfl
    map_mul' := fun g‚āĀ g‚āā => by
      ext l v
      simp only [LinearMap.coe_mk, AddHom.coe_mk, LinearMap.comp_apply,
        Module.End.mul_apply]
      change (centralizerToEndA k (TensorPower k V n) (symGroupImage k V n)
          (glHom (g‚āĀ * g‚āā))) (l v) = _
      rw [map_mul, map_mul]; rfl }
  -- Bundle each L_inner as a finite-dimensional GL_N representation.
  let L : őĻ ‚Üí FDRep k (Matrix.GeneralLinearGroup (Fin N) k) := fun i =>
    FDRep.of (ŌĀ i)
  -- The carrier of `L i` is, by `FGModuleCat.of_carrier`, definitionally
  -- the explicit hom-space `‚Ü•(S' i) ‚Üí‚āó[A] E`. Hence `LinearEquiv.refl`.
  let L_carrier : ‚ąÄ i, (L i : Type u) ‚ČÉ‚āó[k]
      (‚Ü•(S' i) ‚Üí‚āó[symGroupImage k V n] TensorPower k V n) :=
    fun i => LinearEquiv.refl k _
  exact ‚ü®őĻ, hőĻ, hőĻ_dec, S', hS'_simp, hS'_dist, L, L_carrier, e, he‚ü©

end Etingof
