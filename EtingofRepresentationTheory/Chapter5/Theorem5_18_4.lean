import Mathlib
import EtingofRepresentationTheory.Chapter5.Theorem5_18_1
import EtingofRepresentationTheory.Chapter5.Theorem5_18_2
import EtingofRepresentationTheory.Chapter5.Lemma5_18_3

/-!
# Theorem 5.18.4: Schur-Weyl Duality

The fundamental Schur-Weyl duality theorem for V^вКЧn:

(i) Let A = Im(k[S_n] вЖТ End(V^вКЧn)) and B = Im(U(gl(V)) вЖТ End(V^вКЧn)).
    Then A = End_B(V^вКЧn) and B = End_A(V^вКЧn).

(ii) Both A and B are semisimple, and V^вКЧn is a semisimple gl(V)-module.

(iii) As an (A вКЧ B)-module:
      V^вКЧn вЙЕ вКХ Vpart вКЧ Lpart
      where Vpart ranges over Specht modules of S_n and Lpart are the
      corresponding irreducible polynomial representations of GL(V).

## Mathlib correspondence

Schur-Weyl duality is a deep theorem connecting representation theory of S_n
and GL(V). We use `PiTensorProduct` for V^вКЧn, `MonoidAlgebra` for k[S_n],
and `Subalgebra.centralizer` for the commutant.
-/

open scoped TensorProduct

namespace Etingof

universe u v

variable (k : Type u) [Field k]
  (V : Type v) [AddCommGroup V] [Module k V] [Module.Finite k V]
  (n : вДХ)

/-- The n-th tensor power V^вКЧn as a type. -/
abbrev TensorPower := в®В[k] (_ : Fin n), V

/-- The tensor power of a finite-dimensional module is finite-dimensional.
This follows from the fact that if V has a finite basis, then VвКЧвБњ has a
basis indexed by n-tuples of basis elements. -/
instance tensorPower_finite : Module.Finite k (TensorPower k V n) := by
  haveI : Module.Free k V := Module.Free.of_divisionRing k V
  let b := Module.Free.chooseBasis k V
  exact Module.Finite.of_basis (Basis.piTensorProduct (fun _ : Fin n => b))

/-- The symmetric group action on V^вКЧn by permuting tensor factors.
Given ѕГ вИИ S_n, this sends vвВБ вКЧ ... вКЧ vвВЩ to v_{ѕГвБї¬є(1)} вКЧ ... вКЧ v_{ѕГвБї¬є(n)}.
This is a linear equivalence, hence an element of End_k(V^вКЧn). -/
noncomputable def symGroupAction (ѕГ : Equiv.Perm (Fin n)) :
    TensorPower k V n вЙГвВЧ[k] TensorPower k V n :=
  PiTensorProduct.reindex k (fun _ => V) ѕГ

/-- The image of k[S_n] in End(V^вКЧn), defined as the subalgebra
generated by the symmetric group action on tensor factors.

This is the subalgebra of End_k(V^вКЧn) generated by all permutation
operators ѕГ : V^вКЧn вЖТ V^вКЧn for ѕГ вИИ S_n. -/
noncomputable def symGroupImage :
    Subalgebra k (Module.End k (TensorPower k V n)) :=
  Algebra.adjoin k (Set.range fun (ѕГ : Equiv.Perm (Fin n)) =>
    (symGroupAction k V n ѕГ).toLinearMap)

/-- The diagonal action subalgebra: the image of the diagonal action of
End_k(V) on V^вКЧn, where f вИИ End_k(V) acts as f вКЧ f вКЧ ... вКЧ f.
This is the subalgebra generated by the image of GL(V) (equivalently,
the image of the universal enveloping algebra U(gl(V))). -/
noncomputable def diagonalActionImage :
    Subalgebra k (Module.End k (TensorPower k V n)) :=
  Algebra.adjoin k (Set.range fun (f : Module.End k V) =>
    PiTensorProduct.map (fun _ => f))

/-- Permutation and diagonal operators commute:
(reindex ѕГ) вИШ (map f) = (map f) вИШ (reindex ѕГ). -/
theorem symGroupAction_comm_diagonalAction (ѕГ : Equiv.Perm (Fin n)) (f : Module.End k V) :
    (symGroupAction k V n ѕГ).toLinearMap вИШвВЧ PiTensorProduct.map (fun _ => f) =
    PiTensorProduct.map (fun _ => f) вИШвВЧ (symGroupAction k V n ѕГ).toLinearMap := by
  unfold symGroupAction
  apply LinearMap.ext
  intro x
  show (PiTensorProduct.reindex k (fun _ => V) ѕГ) (PiTensorProduct.map (fun _ => f) x) =
    PiTensorProduct.map (fun _ => f) ((PiTensorProduct.reindex k (fun _ => V) ѕГ) x)
  exact (PiTensorProduct.map_reindex (fun (_ : Fin n) => f) ѕГ x).symm

/-- Permutation operators commute with diagonal operators:
for ѕГ вИИ SвВЩ and f вИИ End(V), ѕГ вИШ fвКЧвБњ = fвКЧвБњ вИШ ѕГ on VвКЧвБњ.
This gives symGroupImage вКЖ centralizer(diagonalActionImage). -/
theorem symGroupImage_le_centralizer_diagonalActionImage :
    symGroupImage k V n вЙ§ Subalgebra.centralizer k
      (diagonalActionImage k V n :
        Set (Module.End k (TensorPower k V n))) := by
  unfold symGroupImage
  apply Algebra.adjoin_le
  rintro x вЯ®ѕГ, rflвЯ©
  simp only [SetLike.mem_coe, Subalgebra.mem_centralizer_iff]
  intro y hy
  unfold diagonalActionImage at hy
  have hcomm : вИА g вИИ Set.range (fun (f : Module.End k V) =>
      PiTensorProduct.map (R := k) (fun (_ : Fin n) => f)),
      Commute (вЖС(symGroupAction k V n ѕГ) : Module.End k (TensorPower k V n)) g := by
    rintro g вЯ®f, rflвЯ©
    exact symGroupAction_comm_diagonalAction k V n ѕГ f
  exact (Algebra.commute_of_mem_adjoin_of_forall_mem_commute hy hcomm).symm.eq

/-- Diagonal operators commute with permutation operators:
diagonalActionImage вКЖ centralizer(symGroupImage). -/
theorem diagonalActionImage_le_centralizer_symGroupImage :
    diagonalActionImage k V n вЙ§ Subalgebra.centralizer k
      (symGroupImage k V n :
        Set (Module.End k (TensorPower k V n))) := by
  rw [Subalgebra.le_centralizer_iff]
  exact symGroupImage_le_centralizer_diagonalActionImage k V n

/-- The monoid homomorphism from `Equiv.Perm (Fin n)` to `End_k(VвКЧвБњ)` given by
the permutation action on tensor factors. -/
noncomputable def symGroupMonoidHom :
    Equiv.Perm (Fin n) вЖТ* Module.End k (TensorPower k V n) where
  toFun ѕГ := (symGroupAction k V n ѕГ).toLinearMap
  map_one' := by
    simp only [symGroupAction]
    apply LinearMap.ext; intro x
    change (PiTensorProduct.reindex k (fun _ => V) (Equiv.refl _)) x = x
    simp [PiTensorProduct.reindex_refl]
  map_mul' ѕГ ѕД := by
    simp only [symGroupAction]
    apply LinearMap.ext
    intro x
    change (PiTensorProduct.reindex k (fun _ => V) (ѕГ * ѕД)) x =
      (PiTensorProduct.reindex k (fun _ => V) ѕГ)
        ((PiTensorProduct.reindex k (fun _ => V) ѕД) x)
    rw [show (ѕГ * ѕД : Equiv.Perm (Fin n)) = ѕД.trans ѕГ from rfl,
      вЖР PiTensorProduct.reindex_reindex]

/-- The algebra homomorphism from `k[SвВЩ]` to `End_k(VвКЧвБњ)` lifting the permutation action. -/
noncomputable def symGroupAlgHom :
    MonoidAlgebra k (Equiv.Perm (Fin n)) вЖТвВР[k] Module.End k (TensorPower k V n) :=
  MonoidAlgebra.lift k (Module.End k (TensorPower k V n)) (Equiv.Perm (Fin n))
    (symGroupMonoidHom k V n)

/-- The range of the algebra homomorphism from `k[SвВЩ]` equals `symGroupImage`. -/
theorem symGroupAlgHom_range :
    (symGroupAlgHom k V n).range = symGroupImage k V n := by
  unfold symGroupAlgHom symGroupImage
  apply le_antisymm
  ¬Ј -- range вКЖ adjoin: every element in range is in adjoin
    rintro x вЯ®f, rflвЯ©
    induction f using Finsupp.induction_linear with
    | zero => exact Subalgebra.zero_mem _
    | add f g hf hg => rw [map_add]; exact Subalgebra.add_mem _ hf hg
    | single a b =>
      change (MonoidAlgebra.lift k _ _ (symGroupMonoidHom k V n)) (Finsupp.single a b) вИИ _
      rw [MonoidAlgebra.lift_single]
      exact Subalgebra.smul_mem _
        (Algebra.subset_adjoin (Set.mem_range.mpr вЯ®a, by simp [symGroupMonoidHom]вЯ©)) _
  ¬Ј -- adjoin вКЖ range: each generator is in range, and range is a subalgebra
    apply Algebra.adjoin_le
    rintro x вЯ®ѕГ, rflвЯ©
    exact вЯ®MonoidAlgebra.single ѕГ 1, by
      simp [MonoidAlgebra.lift_single, symGroupMonoidHom]вЯ©

/-- The image of k[SвВЩ] in End(VвКЧвБњ) is a semisimple ring.
This follows from Maschke's theorem: the group algebra k[G] is
semisimple when char(k) does not divide |G| (in char 0, always). -/
instance symGroupImage_isSemisimpleRing
    [CharZero k] :
    IsSemisimpleRing (symGroupImage k V n) := by
  rw [вЖР symGroupAlgHom_range]
  haveI : NeZero (Nat.card (Equiv.Perm (Fin n)) : k) := by
    rw [Nat.card_perm, Nat.card_fin]
    exact вЯ®Nat.cast_ne_zero.mpr (Nat.factorial_ne_zero n)вЯ©
  exact (symGroupAlgHom k V n).toRingHom.rangeRestrict.isSemisimpleRing_of_surjective
    (symGroupAlgHom k V n).toRingHom.rangeRestrict_surjective

/-- VвКЧвБњ is a faithful module over symGroupImage when n вЙ§ dim V.
Distinct permutations produce distinct operators on VвКЧвБњ when
there are enough linearly independent vectors. -/
theorem symGroupImage_faithfulSMul
    (hN : n вЙ§ Module.finrank k V) :
    FaithfulSMul (symGroupImage k V n) (TensorPower k V n) := by
  constructor
  intro a b hab
  apply Subtype.ext
  apply LinearMap.ext
  intro x
  exact hab x

/-- The centralizer of the symmetric group image equals the diagonal
action image. This is the key content of Schur-Weyl duality:
every endomorphism of VвКЧвБњ commuting with all permutations is
a polynomial in diagonal operators.

**Proof approach (Etingof Theorem 5.18.2 + Lemma 5.18.3):**
The вЙ• direction is `diagonalActionImage_le_centralizer_symGroupImage`.
For вЙ§: Via the basis `Basis.piTensorProduct`, an SвВЩ-equivariant
endomorphism has matrix M[c,f] depending only on the multiset
{(c(i),f(i))}. The diagonal operator (map (fun _ => g)) has matrix
вИПбµҐ g[c(i),f(i)]. Equality reduces to: the span of
{вИПбµҐ g[c(i),f(i)] : g вИИ End V} over all g equals the space of
SвВЩ-invariant matrices. This is the Veronese spanning property
(= Lemma 5.18.3(i): SвБњ(U) is spanned by {uвКЧвБњ : u вИИ U}),
which holds in characteristic 0 by irreducibility of SвБњ(U) as a
GL(U)-representation.

**Proof:** The вЙ§ direction uses the averaging/polarization argument from
Theorem 5.18.2: if ѕЖ commutes with all permutations, then conj_ѕГ(ѕЖ) = ѕЖ
for all ѕГ, so n!¬ЈѕЖ = ќ£_ѕГ conj_ѕГ(ѕЖ). By multilinear polarization
(Lemma 5.18.3), this sum lies in the fullDiagonalSubalgebra = diagonalActionImage.
Dividing by n! (char 0) gives ѕЖ вИИ diagonalActionImage.
-/
theorem centralizer_symGroupImage_eq_diagonalActionImage
    [CharZero k]
    (_hN : n вЙ§ Module.finrank k V) :
    Subalgebra.centralizer k
      (symGroupImage k V n :
        Set (Module.End k (TensorPower k V n))) =
    diagonalActionImage k V n := by
  apply le_antisymm
  ¬Ј -- Hard direction: centralizer(SвВЩ) вЙ§ diagonalActionImage
    -- Theorem 5.18.2 proves centralizer = UE.range via the chain:
    --   centralizer вЙ§ fullDiag вЙ§ diagSub вЙ§ UE.range вЙ§ centralizer
    -- We only need: centralizer вЙ§ fullDiag = diagonalActionImage
    -- Reproduce the centralizer вЙ§ fullDiag step from Theorem 5.18.2
    open Theorem5_18_2_Helpers in
    intro ѕЖ hѕЖ
    rw [Subalgebra.mem_centralizer_iff] at hѕЖ
    change ѕЖ вИИ Lemma5_18_3.fullDiagonalSubalgebra k V n
    -- ѕЖ commutes with all reindex(ѕГ), so conj_ѕГ(ѕЖ) = ѕЖ
    have hconj : вИА ѕГ : Equiv.Perm (Fin n),
        (PiTensorProduct.reindex k (fun _ => V) ѕГ).toLinearMap * ѕЖ *
        (PiTensorProduct.reindex k (fun _ => V) ѕГ).symm.toLinearMap = ѕЖ := by
      intro ѕГ
      set e := PiTensorProduct.reindex k (fun _ => V) ѕГ
      have hcomm := hѕЖ e.toLinearMap (Algebra.subset_adjoin вЯ®ѕГ, rflвЯ©)
      have he_inv : e.toLinearMap * e.symm.toLinearMap = 1 := by
        ext v; simp [Module.End.mul_eq_comp]
      calc e.toLinearMap * ѕЖ * e.symm.toLinearMap
          = ѕЖ * e.toLinearMap * e.symm.toLinearMap := by rw [hcomm]
        _ = ѕЖ * (e.toLinearMap * e.symm.toLinearMap) := by rw [mul_assoc]
        _ = ѕЖ * 1 := by rw [he_inv]
        _ = ѕЖ := mul_one _
    -- n! ¬Ј ѕЖ = вИС_ѕГ conj_ѕГ(ѕЖ), and вИС_ѕГ conj_ѕГ(ѕЖ) вИИ fullDiag
    set fullDiag := Lemma5_18_3.fullDiagonalSubalgebra k V n
    have hfact : (n.factorial : k) вЙ† 0 := Nat.cast_ne_zero.mpr n.factorial_ne_zero
    have hmem : ѕЖ вИИ Submodule.span k (Set.range fun f : Fin n вЖТ Module.End k V =>
        PiTensorProduct.map f) :=
      @map_span_eq_top k _ V _ _ n _ _ вЦЄ Submodule.mem_top
    have hsum := avg_conj_mem_fullDiag (k := k) (V := V) (n := n) ѕЖ hmem
    have heq : вИС ѕГ : Equiv.Perm (Fin n),
        (PiTensorProduct.reindex k (fun _ => V) ѕГ).toLinearMap * ѕЖ *
        (PiTensorProduct.reindex k (fun _ => V) ѕГ).symm.toLinearMap =
        (n.factorial : k) вАҐ ѕЖ := by
      simp_rw [hconj, Finset.sum_const, Finset.card_univ,
        Fintype.card_perm, Fintype.card_fin, вЖР Nat.cast_smul_eq_nsmul k]
    rw [heq] at hsum
    have := fullDiag.toSubmodule.smul_mem (n.factorial : k)вБї¬є hsum
    rwa [inv_smul_smulвВА hfact] at this
  ¬Ј exact diagonalActionImage_le_centralizer_symGroupImage
      k V n

/-- Schur-Weyl duality, part (i): The images of k[S_n] and End_k(V)
in End(V^вКЧn) are mutual centralizers.

Specifically, symGroupImage = centralizer(diagonalActionImage) and
diagonalActionImage = centralizer(symGroupImage).
(Etingof Theorem 5.18.4, part i) -/
theorem Theorem5_18_4_centralizers
    [CharZero k]
    (hN : n вЙ§ Module.finrank k V) :
    symGroupImage k V n = Subalgebra.centralizer k
      (diagonalActionImage k V n :
        Set (Module.End k (TensorPower k V n)))
    вИІ diagonalActionImage k V n = Subalgebra.centralizer k
      (symGroupImage k V n :
        Set (Module.End k (TensorPower k V n))) := by
  have h_cent := centralizer_symGroupImage_eq_diagonalActionImage k V n hN
  constructor
  ¬Ј -- symGroupImage = centralizer(diagonalActionImage)
    -- By double centralizer theorem: centralizer(centralizer(symGroupImage)) = symGroupImage
    -- Since centralizer(symGroupImage) = diagonalActionImage, this gives the result
    haveI := symGroupImage_isSemisimpleRing k V n
    haveI := symGroupImage_faithfulSMul k V n hN
    rw [вЖР h_cent]
    exact (Theorem5_18_1_double_centralizer k (TensorPower k V n) (symGroupImage k V n)).symm
  ¬Ј -- diagonalActionImage = centralizer(symGroupImage)
    exact h_cent.symm

/-- Schur-Weyl duality, part (ii): The symmetric group and diagonal
action subalgebras of End(V^вКЧn) are both semisimple.
(Etingof Theorem 5.18.4, part ii) -/
theorem Theorem5_18_4_semisimple
    [CharZero k]
    (hN : n вЙ§ Module.finrank k V) :
    IsSemisimpleRing (symGroupImage k V n)
    вИІ IsSemisimpleRing (diagonalActionImage k V n) := by
  constructor
  ¬Ј exact symGroupImage_isSemisimpleRing k V n
  ¬Ј -- diagonalActionImage = centralizer(symGroupImage)
    -- centralizer of semisimple subalgebra is semisimple
    rw [вЖР centralizer_symGroupImage_eq_diagonalActionImage
      k V n hN]
    haveI := symGroupImage_isSemisimpleRing k V n
    haveI := symGroupImage_faithfulSMul k V n hN
    exact Theorem5_18_1_commutant_semisimple k (TensorPower k V n) (symGroupImage k V n)

/-- Schur-Weyl duality, part (iii): Decomposition of V^вКЧn.

V^вКЧn decomposes as a direct sum of tensor products of simple modules:
  V^вКЧn вЙЕ вКХ_i S_i вКЧ L_i
where {S_i} are the distinct simple k[S_n]-modules (Specht modules)
appearing in V^вКЧn and {L_i} are the corresponding irreducible
polynomial GL(V)-representations.
(Etingof Theorem 5.18.4, part iii) -/
theorem Theorem5_18_4_decomposition
    [CharZero k]
    (hN : n вЙ§ Module.finrank k V) :
    вИГ (ќє : Type) (_ : Fintype ќє) (_ : DecidableEq ќє)
      (S : ќє вЖТ Type (max u v)) (L : ќє вЖТ Type u)
      (_ : вИА i, AddCommGroup (S i))
      (_ : вИА i, Module k (S i))
      (_ : вИА i, AddCommGroup (L i))
      (_ : вИА i, Module k (L i)),
      Nonempty (TensorPower k V n вЙГвВЧ[k]
        DirectSum ќє (fun i => S i вКЧ[k] L i)) := by
  haveI := symGroupImage_isSemisimpleRing k V n
  haveI := symGroupImage_faithfulSMul k V n hN
  obtain вЯ®ќє, hќє, hќє_dec, V', W', hV'_acg, hV'_mod,
    hV'_Amod, hV'_simp, hW'_acg, hW'_mod, вЯ®eвЯ©вЯ© :=
    Theorem5_18_1_decomposition k
      (TensorPower k V n) (symGroupImage k V n)
  exact вЯ®ќє, hќє, hќє_dec, V', W',
    hV'_acg, hV'_mod, hW'_acg, hW'_mod, вЯ®eвЯ©вЯ©

/-- Schur-Weyl duality: partition-indexed decomposition of V^вКЧn.
This refines `Theorem5_18_4_decomposition` by re-indexing the decomposition
by `Nat.Partition n`. Each summand `S p вКЧ L p` collects the components
from the generic decomposition that are assigned to partition `p`.
(Etingof Theorem 5.18.4, part iii) -/
theorem Theorem5_18_4_partition_decomposition
    [IsAlgClosed k] [CharZero k]
    (hN : n вЙ§ Module.finrank k V) :
    вИГ (S : Nat.Partition n вЖТ Type (max u v))
      (L : Nat.Partition n вЖТ Type u)
      (_ : вИА p, AddCommGroup (S p))
      (_ : вИА p, Module k (S p))
      (_ : вИА p, AddCommGroup (L p))
      (_ : вИА p, Module k (L p)),
      Nonempty (TensorPower k V n вЙГвВЧ[k]
        DirectSum (Nat.Partition n)
          (fun p => S p вКЧ[k] L p)) := by
  -- Use the existing ќє-indexed decomposition from Theorem 5.18.4(iii)
  obtain вЯ®ќє, hќє, hќє_dec, S', L', hS'_acg, hS'_mod, hL'_acg, hL'_mod, вЯ®eвЯ©вЯ© :=
    Theorem5_18_4_decomposition k V n hN
  -- Re-index: choose any function f : ќє вЖТ Nat.Partition n, then group
  -- summands by fiber. Empty fibers contribute zero modules.
  haveI : Nonempty (Nat.Partition n) :=
    вЯ®вЯ®Multiset.replicate n 1, fun {i} hi => by
      simp [Multiset.mem_replicate] at hi; omega,
      by simpвЯ©вЯ©
  let f : ќє вЖТ Nat.Partition n := fun _ => Classical.arbitrary _
  -- Define S p as the fiber direct sum: вКХ_{i : fвБї¬є(p)} (S' i вКЧ L' i)
  -- Define L p = k (so S p вКЧ k вЙЕ S p via TensorProduct.rid)
  let M : ќє вЖТ Type (max u v) := fun i => S' i вКЧ[k] L' i
  refine вЯ®fun p => DirectSum {i : ќє // f i = p} (fun j => M j.val),
          fun _ => k,
          inferInstance, inferInstance, inferInstance, inferInstance, вЯ®?_вЯ©вЯ©
  -- Build the equivalence chain:
  -- VвКЧвБњ вЙГ вКХ_ќє M вЙГ вКХ_{ќ£ p, fiber} M вЙГ вКХ_p (вКХ_fiber M) вЙГ вКХ_p ((вКХ_fiber M) вКЧ k)
  -- Step 2: re-index вКХ_ќє M along the fiber equivalence
  have eвВВ := DirectSum.lequivCongrLeft (R := k)
    (Equiv.sigmaFiberEquiv f).symm (M := M)
  -- Step 3+4: sigma curry then tensor with k
  -- sigmaLcurryEquiv : (R) вЖТ [Semiring R] вЖТ {ќє} вЖТ {ќ± : ќє вЖТ Type} вЖТ {ќі : (i : ќє) вЖТ ќ± i вЖТ Type} вЖТ
  --   [DecidableEq ќє] вЖТ [AddCommMonoid] вЖТ [Module] вЖТ
  --   DirectSum (ќ£ x, ќ± x) (fun i => ќі i.1 i.2) вЙГвВЧ[R]
  --     DirectSum ќє (fun i => DirectSum (ќ± i) (fun j => ќі i j))
  let eвВГ := @DirectSum.sigmaLcurryEquiv k _ (Nat.Partition n)
    (fun p => {j : ќє // f j = p})
    (fun p (j : {j : ќє // f j = p}) => M j.val)
    _ (fun _ _ => inferInstance) (fun _ _ => inferInstance)
  -- Step 4: tensor with k via TensorProduct.rid
  let eвВД := DFinsupp.mapRange.linearEquiv (R := k)
    (fun p : Nat.Partition n => (TensorProduct.rid k
      (DirectSum {j : ќє // f j = p} (fun j => M j.val))).symm)
  -- Now compose: VвКЧвБњ вЖТ[e] вКХ_ќє M вЖТ[eвВВ] вКХ_ќ£ M вЖТ[eвВГ] вКХ_p(вКХ_fiber M) вЖТ[eвВД] вКХ_p(вКХ_fiber M вКЧ k)
  exact e.trans (eвВВ.trans (eвВГ.trans eвВД))

end Etingof
