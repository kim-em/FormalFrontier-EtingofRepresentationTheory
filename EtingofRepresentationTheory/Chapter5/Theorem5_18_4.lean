  haveI : Module.Finite k V := inferInstance
  have hfinrank : Module.finrank k V = N :=
    (Module.finrank_pi k).trans (Fintype.card_fin N)
  have hN' : n ÔëĄ Module.finrank k V := hfinrank.symm ÔľŞ hN
  haveI := symGroupImage_isSemisimpleRing k V n
  haveI := symGroupImage_faithfulSMul k V n hN'
  -- Get the explicit bimodule decomposition with concrete summand types
  -- and the evaluation formula.
  obtain ÔčĘ╬╣, h╬╣, h╬╣_dec, S', hS'_simp, hS'_dist, hS'_fin, e, heÔčę :=
    Theorem5_18_4_bimodule_decomposition_explicit k V n hN'
  -- Centralizer identity: centralizer(symGroupImage) = diagonalActionImage.
  have h_eq : Subalgebra.centralizer k
      (symGroupImage k V n : Set (Module.End k (TensorPower k V n))) =
        diagonalActionImage k V n :=
    (Theorem5_18_4_centralizers k V n hN').2.symm
  -- Monoid hom GL_N Ôćĺ centralizer(symGroupImage):
  --   g ÔćŽ PiTensorProduct.map (fun _ => mulVecLin g.val).
  -- Its image lies in `diagonalActionImage` by definition, hence in the
  -- centralizer via `h_eq`.
  let glHom : Matrix.GeneralLinearGroup (Fin N) k Ôćĺ*
      Ôćą(Subalgebra.centralizer k
        (symGroupImage k V n : Set (Module.End k (TensorPower k V n)))) :=
  { toFun := fun g => ÔčĘPiTensorProduct.map
        (fun _ : Fin n => Matrix.mulVecLin (R := k) g.val), by
      rw [h_eq]
      exact Algebra.subset_adjoin ÔčĘMatrix.mulVecLin g.val, rflÔčęÔčę
    map_one' := by
      apply Subtype.ext
      change PiTensorProduct.map
          (fun _ : Fin n => Matrix.mulVecLin (R := k) (1 : Matrix _ _ k)) = 1
      have : (fun _ : Fin n => Matrix.mulVecLin (R := k) (1 : Matrix _ _ k)) =
          (fun _ : Fin n => (LinearMap.id : V ÔćĺÔéŚ[k] V)) :=
        funext fun _ => Matrix.mulVecLin_one
      rw [this, PiTensorProduct.map_id]; rfl
    map_mul' := fun gÔéü gÔéé => by
      apply Subtype.ext
      change PiTensorProduct.map
          (fun _ : Fin n => Matrix.mulVecLin (R := k) (gÔéü.val * gÔéé.val)) =
        PiTensorProduct.map
            (fun _ : Fin n => Matrix.mulVecLin (R := k) gÔéü.val) *
          PiTensorProduct.map
            (fun _ : Fin n => Matrix.mulVecLin (R := k) gÔéé.val)
      have : (fun _ : Fin n => Matrix.mulVecLin (R := k) (gÔéü.val * gÔéé.val)) =
          (fun _ : Fin n => (Matrix.mulVecLin gÔéü.val).comp
            (Matrix.mulVecLin gÔéé.val)) :=
        funext fun _ => Matrix.mulVecLin_mul gÔéü.val gÔéé.val
      rw [this, PiTensorProduct.map_comp]; rfl }
  -- The `A`-linear hom space `Ôćą(S' i) ÔćĺÔéŚ[A] E` is finite-dimensional over `k`
  -- because it injects (`k`-linearly) into the `k`-linear hom space, which has
  -- dimension `dim(Ôćą(S' i)) ┬Ě dim(E)`. (`Module.Finite k Ôćą(S' i)` is now
  -- propagated from `Theorem5_18_4_bimodule_decomposition_explicit` as
  -- `hS'_fin`.)
  haveI hLi_fin : ÔłÇ i, Module.Finite k
      ((Ôćą(S' i) : Type u) ÔćĺÔéŚ[symGroupImage k V n] TensorPower k V n) :=
    fun i => by
      haveI : Module.Finite k (Ôćą(S' i) : Type u) := hS'_fin i
      haveI : Module.Free k (Ôćą(S' i) : Type u) :=
        Module.Free.of_divisionRing k (Ôćą(S' i))
      haveI : Module.Finite k
          ((Ôćą(S' i) : Type u) ÔćĺÔéŚ[k] TensorPower k V n) :=
        Module.Finite.linearMap k k (Ôćą(S' i)) (TensorPower k V n)
      exact Module.Finite.of_injective
        (LinearMap.restrictScalarsÔéŚ k (symGroupImage k V n) (Ôćą(S' i))
          (TensorPower k V n) k)
        (LinearMap.restrictScalars_injective _)
  -- For each i, build the GL_N representation on `Ôćą(S' i) ÔćĺÔéŚ[A] E` directly:
  -- `g ┬Ě l := (centralizerToEndA (glHom g)).comp l`. Manual construction
  -- bypasses an instance-synthesis diamond on the centralizer-Module
  -- structure of the hom-space. (Same construction as in
  -- `glTensorRep_equivariant_schurWeyl_decomposition`.)
  let ¤ü : ÔłÇ i, Matrix.GeneralLinearGroup (Fin N) k Ôćĺ*
      Module.End k (Ôćą(S' i) ÔćĺÔéŚ[symGroupImage k V n] TensorPower k V n) := fun i =>
  { toFun := fun g =>
    { toFun := fun l =>
        (centralizerToEndA k (TensorPower k V n) (symGroupImage k V n)
          (glHom g)).comp l
      map_add' := fun lÔéü lÔéé => by
        ext v
        simp only [LinearMap.comp_apply, LinearMap.add_apply, map_add]
      map_smul' := fun c l => by
        ext v
        simp only [LinearMap.smul_apply, RingHom.id_apply,
          LinearMap.comp_apply, LinearMap.map_smul_of_tower] }
    map_one' := by
      ext l v
      simp only [LinearMap.coe_mk, AddHom.coe_mk, LinearMap.comp_apply,
        Module.End.one_apply]
      change (centralizerToEndA k (TensorPower k V n) (symGroupImage k V n)
        (glHom 1)) (l v) = l v
      rw [map_one, map_one]; rfl
    map_mul' := fun gÔéü gÔéé => by
      ext l v
      simp only [LinearMap.coe_mk, AddHom.coe_mk, LinearMap.comp_apply,
        Module.End.mul_apply]
      change (centralizerToEndA k (TensorPower k V n) (symGroupImage k V n)
          (glHom (gÔéü * gÔéé))) (l v) = _
      rw [map_mul, map_mul]; rfl }
  -- Bundle each L_inner as a finite-dimensional GL_N representation.
  let L : ╬╣ Ôćĺ FDRep k (Matrix.GeneralLinearGroup (Fin N) k) := fun i =>
    FDRep.of (¤ü i)
  -- The carrier of `L i` is, by `FGModuleCat.of_carrier`, definitionally
  -- the explicit hom-space `Ôćą(S' i) ÔćĺÔéŚ[A] E`. Hence `LinearEquiv.refl`.
  let L_carrier : ÔłÇ i, (L i : Type u) ÔëâÔéŚ[k]
      (Ôćą(S' i) ÔćĺÔéŚ[symGroupImage k V n] TensorPower k V n) :=
    fun i => LinearEquiv.refl k _
  -- Action formula: `((L i).¤ü g l) v = PiTensorProduct.map (mulVecLin g.val) (l v)`
  -- because `(L i).¤ü = ¤ü i` and `¤ü i g l = (centralizerToEndA (glHom g)).comp l`
  -- whose underlying map is `PiTensorProduct.map (mulVecLin g.val)`.
  refine ÔčĘ╬╣, h╬╣, h╬╣_dec, S', hS'_simp, hS'_dist, hS'_fin, L, L_carrier, e, he, ?_Ôčę
  intro i g l v
  rfl

