/-- Schur-Weyl duality, part (iii), GL_N representation form.

Specialized to `V = Fin N ‚Üí k` (the only case used downstream): as a
module over `(symGroupImage k V n) ‚äó[k] (GL_N k)`, `V^‚äón` decomposes as
  `V^‚äón ‚ČÖ ‚®ĀŠĶĘ SŠĶĘ ‚äó[k] LŠĶĘ`
where the `SŠĶĘ` are pairwise non-isomorphic simple `symGroupImage`-modules
(Specht modules) and each `LŠĶĘ` is a full finite-dimensional
`GL_N(k)`-representation (an irreducible polynomial representation).

Refines `Theorem5_18_4_bimodule_decomposition` by upgrading each `LŠĶĘ`
from a `Module (diagonalActionImage) LŠĶĘ` to a bundled
`FDRep k (GL_N k)`. The `GL_N` action is built by composing
`GL_N ‚Üí diagonalActionImage` (via the `g ‚Ü¶ g^{‚äón}` diagonal map) with
the existing `diagonalActionImage`-module structure. -/
theorem Theorem5_18_4_GL_rep_decomposition
    (k : Type u) [Field k] [IsAlgClosed k] [CharZero k]
    (N n : ‚Ąē) (hN : n ‚Č§ N) :
    ‚ąÉ (őĻ : Type) (_ : Fintype őĻ) (_ : DecidableEq őĻ)
      (S : őĻ ‚Üí Type u)
      (_ : ‚ąÄ i, AddCommGroup (S i))
      (_ : ‚ąÄ i, Module k (S i))
      (_ : ‚ąÄ i, Module (symGroupImage k (Fin N ‚Üí k) n) (S i))
      (_ : ‚ąÄ i, IsSimpleModule (symGroupImage k (Fin N ‚Üí k) n) (S i))
      (_ : ‚ąÄ i j,
        Nonempty (S i ‚ČÉ‚āó[symGroupImage k (Fin N ‚Üí k) n] S j) ‚Üí i = j)
      (_ : ‚ąÄ i, Module.Finite k (S i))
      (L : őĻ ‚Üí FDRep k (Matrix.GeneralLinearGroup (Fin N) k)),
      Nonempty (TensorPower k (Fin N ‚Üí k) n ‚ČÉ‚āó[k]
        DirectSum őĻ (fun i => S i ‚äó[k] (L i : Type u))) := by
  set V : Type u := Fin N ‚Üí k with hV
  haveI : Module.Finite k V := inferInstance
  have hfinrank : Module.finrank k V = N :=
    (Module.finrank_pi k).trans (Fintype.card_fin N)
  have hN' : n ‚Č§ Module.finrank k V := hfinrank.symm ‚Ėł hN
  haveI := symGroupImage_isSemisimpleRing k V n
  haveI := symGroupImage_faithfulSMul k V n hN'
  -- Get the bimodule decomposition with L_i carrying a Module over
  -- the centralizer of symGroupImage and the associated SMulCommClass.
  obtain ‚ü®őĻ, hőĻ, hőĻ_dec, S', hS'_acg, hS'_mod, hS'_Amod, hS'_simp,
    hS'_dist, hS'_fin, L', hL'_acg, hL'_mod, hL'_Bmod, hL'_smul, hL'_fin, ‚ü®e‚ü©‚ü© :=
    Theorem5_18_1_bimodule_decomposition k (TensorPower k V n)
      (symGroupImage k V n)
  -- Centralizer identity: centralizer(symGroupImage) = diagonalActionImage.
  have h_eq : Subalgebra.centralizer k
      (symGroupImage k V n : Set (Module.End k (TensorPower k V n))) =
        diagonalActionImage k V n :=
    (Theorem5_18_4_centralizers k V n hN').2.symm
  -- Monoid hom GL_N ‚Üí centralizer(symGroupImage):
  --   g ‚Ü¶ PiTensorProduct.map (fun _ => mulVecLin g.val)
  -- Its image lies in diagonalActionImage by definition, hence in the
  -- centralizer via h_eq.
  let glHom : Matrix.GeneralLinearGroup (Fin N) k ‚Üí*
      ‚Ü•(Subalgebra.centralizer k
        (symGroupImage k V n : Set (Module.End k (TensorPower k V n)))) :=
  { toFun := fun g => ‚ü®PiTensorProduct.map
        (fun _ : Fin n => Matrix.mulVecLin (R := k) g.val), by
      rw [h_eq]
      exact Algebra.subset_adjoin ‚ü®Matrix.mulVecLin g.val, rfl‚ü©‚ü©
    map_one' := by
      apply Subtype.ext
      change PiTensorProduct.map
          (fun _ : Fin n => Matrix.mulVecLin (R := k) (1 : Matrix _ _ k)) = 1
      have : (fun _ : Fin n => Matrix.mulVecLin (R := k) (1 : Matrix _ _ k)) =
          (fun _ : Fin n => (LinearMap.id : V ‚Üí‚āó[k] V)) :=
        funext fun _ => Matrix.mulVecLin_one
      rw [this, PiTensorProduct.map_id]; rfl
    map_mul' := fun g‚āĀ g‚āā => by
      apply Subtype.ext
      change PiTensorProduct.map
          (fun _ : Fin n => Matrix.mulVecLin (R := k) (g‚āĀ.val * g‚āā.val)) =
        PiTensorProduct.map
            (fun _ : Fin n => Matrix.mulVecLin (R := k) g‚āĀ.val) *
          PiTensorProduct.map
            (fun _ : Fin n => Matrix.mulVecLin (R := k) g‚āā.val)
      have : (fun _ : Fin n => Matrix.mulVecLin (R := k) (g‚āĀ.val * g‚āā.val)) =
          (fun _ : Fin n => (Matrix.mulVecLin g‚āĀ.val).comp
            (Matrix.mulVecLin g‚āā.val)) :=
        funext fun _ => Matrix.mulVecLin_mul g‚āĀ.val g‚āā.val
      rw [this, PiTensorProduct.map_comp]; rfl }
  -- For each i, build the GL_N representation on L' i.
  let ŌĀ : ‚ąÄ i,
      Matrix.GeneralLinearGroup (Fin N) k ‚Üí* Module.End k (L' i) := fun i =>
    (Module.toModuleEnd k (L' i)
      (S := ‚Ü•(Subalgebra.centralizer k
        (symGroupImage k V n :
          Set (Module.End k (TensorPower k V n)))))).toMonoidHom.comp glHom
  -- Bundle each L' i as a finite-dimensional GL_N representation.
  let L : őĻ ‚Üí FDRep k (Matrix.GeneralLinearGroup (Fin N) k) := fun i =>
    FDRep.of (ŌĀ i)
  exact ‚ü®őĻ, hőĻ, hőĻ_dec, S', hS'_acg, hS'_mod, hS'_Amod, hS'_simp,
    hS'_dist, hS'_fin, L, ‚ü®e‚ü©‚ü©

