    (k : Type u) [Field k] [IsAlgClosed k] [CharZero k]
    (N n : ÔäĽ) (hN : n ÔëĄ N) :
    Ôłâ (╬╣ : Type) (_ : Fintype ╬╣) (_ : DecidableEq ╬╣)
      (S : ╬╣ Ôćĺ Submodule (symGroupImage k (Fin N Ôćĺ k) n)
        (TensorPower k (Fin N Ôćĺ k) n))
      (_ : ÔłÇ i, IsSimpleModule (symGroupImage k (Fin N Ôćĺ k) n) (S i))
      (_ : ÔłÇ i j,
        Nonempty (Ôćą(S i) ÔëâÔéŚ[symGroupImage k (Fin N Ôćĺ k) n] Ôćą(S j)) Ôćĺ i = j)
      (_ : ÔłÇ i, Module.Finite k Ôćą(S i))
      (L : ╬╣ Ôćĺ FDRep k (Matrix.GeneralLinearGroup (Fin N) k))
      (L_carrier : ÔłÇ i, (L i : Type u) ÔëâÔéŚ[k]
        (Ôćą(S i) ÔćĺÔéŚ[symGroupImage k (Fin N Ôćĺ k) n]
          TensorPower k (Fin N Ôćĺ k) n)),
      Ôłâ (e : TensorPower k (Fin N Ôćĺ k) n ÔëâÔéŚ[k]
          DirectSum ╬╣ (fun i => Ôćą(S i) ÔŐŚ[k] (L i : Type u))),
        (ÔłÇ (i : ╬╣) (v : Ôćą(S i)) (l : (L i : Type u)),
          e.symm (DirectSum.of (fun i => Ôćą(S i) ÔŐŚ[k] (L i : Type u)) i
              (v ÔŐŚÔéť[k] l)) = (L_carrier i l) v) Ôłž
        (ÔłÇ (i : ╬╣) (g : Matrix.GeneralLinearGroup (Fin N) k)
            (l : (L i : Type u)) (v : Ôćą(S i)),
          (L_carrier i ((L i).¤ü g l)) v =
            PiTensorProduct.map
              (fun _ : Fin n => Matrix.mulVecLin (R := k) g.val)
              ((L_carrier i l) v)) := by
