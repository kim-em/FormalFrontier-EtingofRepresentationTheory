import Mathlib
import EtingofRepresentationTheory.Chapter5.Theorem5_18_1
import EtingofRepresentationTheory.Chapter5.Theorem5_18_2
import EtingofRepresentationTheory.Chapter5.Lemma5_18_3

/-!
# Theorem 5.18.4: Schur-Weyl Duality

The fundamental Schur-Weyl duality theorem for V^‚äón:

(i) Let A = Im(k[S_n] ‚Üí End(V^‚äón)) and B = Im(U(gl(V)) ‚Üí End(V^‚äón)).
    Then A = End_B(V^‚äón) and B = End_A(V^‚äón).

(ii) Both A and B are semisimple, and V^‚äón is a semisimple gl(V)-module.

(iii) As an (A ‚äó B)-module:
      V^‚äón ‚ČÖ ‚äē Vpart ‚äó Lpart
      where Vpart ranges over Specht modules of S_n and Lpart are the
      corresponding irreducible polynomial representations of GL(V).

## Mathlib correspondence

Schur-Weyl duality is a deep theorem connecting representation theory of S_n
and GL(V). We use `PiTensorProduct` for V^‚äón, `MonoidAlgebra` for k[S_n],
and `Subalgebra.centralizer` for the commutant.
-/

open scoped TensorProduct

namespace Etingof

universe u v

variable (k : Type u) [Field k]
  (V : Type v) [AddCommGroup V] [Module k V] [Module.Finite k V]
  (n : ‚Ąē)

/-- The n-th tensor power V^‚äón as a type. -/
abbrev TensorPower := ‚®ā[k] (_ : Fin n), V

/-- The tensor power of a finite-dimensional module is finite-dimensional.
This follows from the fact that if V has a finite basis, then V‚äó‚ĀŅ has a
basis indexed by n-tuples of basis elements. -/
instance tensorPower_finite : Module.Finite k (TensorPower k V n) := by
  haveI : Module.Free k V := Module.Free.of_divisionRing k V
  let b := Module.Free.chooseBasis k V
  exact Module.Finite.of_basis (Basis.piTensorProduct (fun _ : Fin n => b))

/-- The symmetric group action on V^‚äón by permuting tensor factors.
Given ŌÉ ‚ąą S_n, this sends v‚āĀ ‚äó ... ‚äó v‚āô to v_{ŌÉ‚ĀĽ¬Ļ(1)} ‚äó ... ‚äó v_{ŌÉ‚ĀĽ¬Ļ(n)}.
This is a linear equivalence, hence an element of End_k(V^‚äón). -/
noncomputable def symGroupAction (ŌÉ : Equiv.Perm (Fin n)) :
    TensorPower k V n ‚ČÉ‚āó[k] TensorPower k V n :=
  PiTensorProduct.reindex k (fun _ => V) ŌÉ

/-- The image of k[S_n] in End(V^‚äón), defined as the subalgebra
generated by the symmetric group action on tensor factors.

This is the subalgebra of End_k(V^‚äón) generated by all permutation
operators ŌÉ : V^‚äón ‚Üí V^‚äón for ŌÉ ‚ąą S_n. -/
noncomputable def symGroupImage :
    Subalgebra k (Module.End k (TensorPower k V n)) :=
  Algebra.adjoin k (Set.range fun (ŌÉ : Equiv.Perm (Fin n)) =>
    (symGroupAction k V n ŌÉ).toLinearMap)

/-- The diagonal action subalgebra: the image of the diagonal action of
End_k(V) on V^‚äón, where f ‚ąą End_k(V) acts as f ‚äó f ‚äó ... ‚äó f.
This is the subalgebra generated by the image of GL(V) (equivalently,
the image of the universal enveloping algebra U(gl(V))). -/
noncomputable def diagonalActionImage :
    Subalgebra k (Module.End k (TensorPower k V n)) :=
  Algebra.adjoin k (Set.range fun (f : Module.End k V) =>
    PiTensorProduct.map (fun _ => f))

/-- Permutation and diagonal operators commute:
(reindex ŌÉ) ‚ąė (map f) = (map f) ‚ąė (reindex ŌÉ). -/
theorem symGroupAction_comm_diagonalAction (ŌÉ : Equiv.Perm (Fin n)) (f : Module.End k V) :
    (symGroupAction k V n ŌÉ).toLinearMap ‚ąė‚āó PiTensorProduct.map (fun _ => f) =
    PiTensorProduct.map (fun _ => f) ‚ąė‚āó (symGroupAction k V n ŌÉ).toLinearMap := by
  unfold symGroupAction
  apply LinearMap.ext
  intro x
  show (PiTensorProduct.reindex k (fun _ => V) ŌÉ) (PiTensorProduct.map (fun _ => f) x) =
    PiTensorProduct.map (fun _ => f) ((PiTensorProduct.reindex k (fun _ => V) ŌÉ) x)
  exact (PiTensorProduct.map_reindex (fun (_ : Fin n) => f) ŌÉ x).symm

/-- Permutation operators commute with diagonal operators:
for ŌÉ ‚ąą S‚āô and f ‚ąą End(V), ŌÉ ‚ąė f‚äó‚ĀŅ = f‚äó‚ĀŅ ‚ąė ŌÉ on V‚äó‚ĀŅ.
This gives symGroupImage ‚äÜ centralizer(diagonalActionImage). -/
theorem symGroupImage_le_centralizer_diagonalActionImage :
    symGroupImage k V n ‚Č§ Subalgebra.centralizer k
      (diagonalActionImage k V n :
        Set (Module.End k (TensorPower k V n))) := by
  unfold symGroupImage
  apply Algebra.adjoin_le
  rintro x ‚ü®ŌÉ, rfl‚ü©
  simp only [SetLike.mem_coe, Subalgebra.mem_centralizer_iff]
  intro y hy
  unfold diagonalActionImage at hy
  have hcomm : ‚ąÄ g ‚ąą Set.range (fun (f : Module.End k V) =>
      PiTensorProduct.map (R := k) (fun (_ : Fin n) => f)),
      Commute (‚ÜĎ(symGroupAction k V n ŌÉ) : Module.End k (TensorPower k V n)) g := by
    rintro g ‚ü®f, rfl‚ü©
    exact symGroupAction_comm_diagonalAction k V n ŌÉ f
  exact (Algebra.commute_of_mem_adjoin_of_forall_mem_commute hy hcomm).symm.eq

/-- Diagonal operators commute with permutation operators:
diagonalActionImage ‚äÜ centralizer(symGroupImage). -/
theorem diagonalActionImage_le_centralizer_symGroupImage :
    diagonalActionImage k V n ‚Č§ Subalgebra.centralizer k
      (symGroupImage k V n :
        Set (Module.End k (TensorPower k V n))) := by
  rw [Subalgebra.le_centralizer_iff]
  exact symGroupImage_le_centralizer_diagonalActionImage k V n

/-- The monoid homomorphism from `Equiv.Perm (Fin n)` to `End_k(V‚äó‚ĀŅ)` given by
the permutation action on tensor factors. -/
noncomputable def symGroupMonoidHom :
    Equiv.Perm (Fin n) ‚Üí* Module.End k (TensorPower k V n) where
  toFun ŌÉ := (symGroupAction k V n ŌÉ).toLinearMap
  map_one' := by
    simp only [symGroupAction]
    apply LinearMap.ext; intro x
    change (PiTensorProduct.reindex k (fun _ => V) (Equiv.refl _)) x = x
    simp [PiTensorProduct.reindex_refl]
  map_mul' ŌÉ ŌĄ := by
    simp only [symGroupAction]
    apply LinearMap.ext
    intro x
    change (PiTensorProduct.reindex k (fun _ => V) (ŌÉ * ŌĄ)) x =
      (PiTensorProduct.reindex k (fun _ => V) ŌÉ)
        ((PiTensorProduct.reindex k (fun _ => V) ŌĄ) x)
    rw [show (ŌÉ * ŌĄ : Equiv.Perm (Fin n)) = ŌĄ.trans ŌÉ from rfl,
      ‚Üź PiTensorProduct.reindex_reindex]

/-- The algebra homomorphism from `k[S‚āô]` to `End_k(V‚äó‚ĀŅ)` lifting the permutation action. -/
noncomputable def symGroupAlgHom :
    MonoidAlgebra k (Equiv.Perm (Fin n)) ‚Üí‚āź[k] Module.End k (TensorPower k V n) :=
  MonoidAlgebra.lift k (Module.End k (TensorPower k V n)) (Equiv.Perm (Fin n))
    (symGroupMonoidHom k V n)

/-- The range of the algebra homomorphism from `k[S‚āô]` equals `symGroupImage`. -/
theorem symGroupAlgHom_range :
    (symGroupAlgHom k V n).range = symGroupImage k V n := by
  unfold symGroupAlgHom symGroupImage
  apply le_antisymm
  ¬∑ -- range ‚äÜ adjoin: every element in range is in adjoin
    rintro x ‚ü®f, rfl‚ü©
    induction f using Finsupp.induction_linear with
    | zero => exact Subalgebra.zero_mem _
    | add f g hf hg => rw [map_add]; exact Subalgebra.add_mem _ hf hg
    | single a b =>
      change (MonoidAlgebra.lift k _ _ (symGroupMonoidHom k V n)) (Finsupp.single a b) ‚ąą _
      rw [MonoidAlgebra.lift_single]
      exact Subalgebra.smul_mem _
        (Algebra.subset_adjoin (Set.mem_range.mpr ‚ü®a, by simp [symGroupMonoidHom]‚ü©)) _
  ¬∑ -- adjoin ‚äÜ range: each generator is in range, and range is a subalgebra
    apply Algebra.adjoin_le
    rintro x ‚ü®ŌÉ, rfl‚ü©
    exact ‚ü®MonoidAlgebra.single ŌÉ 1, by
      simp [MonoidAlgebra.lift_single, symGroupMonoidHom]‚ü©

/-- The image of k[S‚āô] in End(V‚äó‚ĀŅ) is a semisimple ring.
This follows from Maschke's theorem: the group algebra k[G] is
semisimple when char(k) does not divide |G| (in char 0, always). -/
instance symGroupImage_isSemisimpleRing
    [CharZero k] :
    IsSemisimpleRing (symGroupImage k V n) := by
  rw [‚Üź symGroupAlgHom_range]
  haveI : NeZero (Nat.card (Equiv.Perm (Fin n)) : k) := by
    rw [Nat.card_perm, Nat.card_fin]
    exact ‚ü®Nat.cast_ne_zero.mpr (Nat.factorial_ne_zero n)‚ü©
  exact (symGroupAlgHom k V n).toRingHom.rangeRestrict.isSemisimpleRing_of_surjective
    (symGroupAlgHom k V n).toRingHom.rangeRestrict_surjective

/-- V‚äó‚ĀŅ is a faithful module over symGroupImage when n ‚Č§ dim V.
Distinct permutations produce distinct operators on V‚äó‚ĀŅ when
there are enough linearly independent vectors. -/
theorem symGroupImage_faithfulSMul
    (hN : n ‚Č§ Module.finrank k V) :
    FaithfulSMul (symGroupImage k V n) (TensorPower k V n) := by
  constructor
  intro a b hab
  apply Subtype.ext
  apply LinearMap.ext
  intro x
  exact hab x

/-- The centralizer of the symmetric group image equals the diagonal
action image. This is the key content of Schur-Weyl duality:
every endomorphism of V‚äó‚ĀŅ commuting with all permutations is
a polynomial in diagonal operators.

**Proof approach (Etingof Theorem 5.18.2 + Lemma 5.18.3):**
The ‚Č• direction is `diagonalActionImage_le_centralizer_symGroupImage`.
For ‚Č§: Via the basis `Basis.piTensorProduct`, an S‚āô-equivariant
endomorphism has matrix M[c,f] depending only on the multiset
{(c(i),f(i))}. The diagonal operator (map (fun _ => g)) has matrix
‚ąŹŠĶĘ g[c(i),f(i)]. Equality reduces to: the span of
{‚ąŹŠĶĘ g[c(i),f(i)] : g ‚ąą End V} over all g equals the space of
S‚āô-invariant matrices. This is the Veronese spanning property
(= Lemma 5.18.3(i): S‚ĀŅ(U) is spanned by {u‚äó‚ĀŅ : u ‚ąą U}),
which holds in characteristic 0 by irreducibility of S‚ĀŅ(U) as a
GL(U)-representation.

**Proof:** The ‚Č§ direction uses the averaging/polarization argument from
Theorem 5.18.2: if ŌÜ commutes with all permutations, then conj_ŌÉ(ŌÜ) = ŌÜ
for all ŌÉ, so n!¬∑ŌÜ = ő£_ŌÉ conj_ŌÉ(ŌÜ). By multilinear polarization
(Lemma 5.18.3), this sum lies in the fullDiagonalSubalgebra = diagonalActionImage.
Dividing by n! (char 0) gives ŌÜ ‚ąą diagonalActionImage.
-/
theorem centralizer_symGroupImage_eq_diagonalActionImage
    [CharZero k]
    (_hN : n ‚Č§ Module.finrank k V) :
    Subalgebra.centralizer k
      (symGroupImage k V n :
        Set (Module.End k (TensorPower k V n))) =
    diagonalActionImage k V n := by
  apply le_antisymm
  ¬∑ -- Hard direction: centralizer(S‚āô) ‚Č§ diagonalActionImage
    -- Theorem 5.18.2 proves centralizer = UE.range via the chain:
    --   centralizer ‚Č§ fullDiag ‚Č§ diagSub ‚Č§ UE.range ‚Č§ centralizer
    -- We only need: centralizer ‚Č§ fullDiag = diagonalActionImage
    -- Reproduce the centralizer ‚Č§ fullDiag step from Theorem 5.18.2
    open Theorem5_18_2_Helpers in
    intro ŌÜ hŌÜ
    rw [Subalgebra.mem_centralizer_iff] at hŌÜ
    change ŌÜ ‚ąą Lemma5_18_3.fullDiagonalSubalgebra k V n
    -- ŌÜ commutes with all reindex(ŌÉ), so conj_ŌÉ(ŌÜ) = ŌÜ
    have hconj : ‚ąÄ ŌÉ : Equiv.Perm (Fin n),
        (PiTensorProduct.reindex k (fun _ => V) ŌÉ).toLinearMap * ŌÜ *
        (PiTensorProduct.reindex k (fun _ => V) ŌÉ).symm.toLinearMap = ŌÜ := by
      intro ŌÉ
      set e := PiTensorProduct.reindex k (fun _ => V) ŌÉ
      have hcomm := hŌÜ e.toLinearMap (Algebra.subset_adjoin ‚ü®ŌÉ, rfl‚ü©)
      have he_inv : e.toLinearMap * e.symm.toLinearMap = 1 := by
        ext v; simp [Module.End.mul_eq_comp]
      calc e.toLinearMap * ŌÜ * e.symm.toLinearMap
          = ŌÜ * e.toLinearMap * e.symm.toLinearMap := by rw [hcomm]
        _ = ŌÜ * (e.toLinearMap * e.symm.toLinearMap) := by rw [mul_assoc]
        _ = ŌÜ * 1 := by rw [he_inv]
        _ = ŌÜ := mul_one _
    -- n! ¬∑ ŌÜ = ‚ąĎ_ŌÉ conj_ŌÉ(ŌÜ), and ‚ąĎ_ŌÉ conj_ŌÉ(ŌÜ) ‚ąą fullDiag
    set fullDiag := Lemma5_18_3.fullDiagonalSubalgebra k V n
    have hfact : (n.factorial : k) ‚Č† 0 := Nat.cast_ne_zero.mpr n.factorial_ne_zero
    have hmem : ŌÜ ‚ąą Submodule.span k (Set.range fun f : Fin n ‚Üí Module.End k V =>
        PiTensorProduct.map f) :=
      @map_span_eq_top k _ V _ _ n _ _ ‚Ėł Submodule.mem_top
    have hsum := avg_conj_mem_fullDiag (k := k) (V := V) (n := n) ŌÜ hmem
    have heq : ‚ąĎ ŌÉ : Equiv.Perm (Fin n),
        (PiTensorProduct.reindex k (fun _ => V) ŌÉ).toLinearMap * ŌÜ *
        (PiTensorProduct.reindex k (fun _ => V) ŌÉ).symm.toLinearMap =
        (n.factorial : k) ‚ÄĘ ŌÜ := by
      simp_rw [hconj, Finset.sum_const, Finset.card_univ,
        Fintype.card_perm, Fintype.card_fin, ‚Üź Nat.cast_smul_eq_nsmul k]
    rw [heq] at hsum
    have := fullDiag.toSubmodule.smul_mem (n.factorial : k)‚ĀĽ¬Ļ hsum
    rwa [inv_smul_smul‚āÄ hfact] at this
  ¬∑ exact diagonalActionImage_le_centralizer_symGroupImage
      k V n

/-- Schur-Weyl duality, part (i): The images of k[S_n] and End_k(V)
in End(V^‚äón) are mutual centralizers.

Specifically, symGroupImage = centralizer(diagonalActionImage) and
diagonalActionImage = centralizer(symGroupImage).
(Etingof Theorem 5.18.4, part i) -/
theorem Theorem5_18_4_centralizers
    [CharZero k]
    (hN : n ‚Č§ Module.finrank k V) :
    symGroupImage k V n = Subalgebra.centralizer k
      (diagonalActionImage k V n :
        Set (Module.End k (TensorPower k V n)))
    ‚ąß diagonalActionImage k V n = Subalgebra.centralizer k
      (symGroupImage k V n :
        Set (Module.End k (TensorPower k V n))) := by
  have h_cent := centralizer_symGroupImage_eq_diagonalActionImage k V n hN
  constructor
  ¬∑ -- symGroupImage = centralizer(diagonalActionImage)
    -- By double centralizer theorem: centralizer(centralizer(symGroupImage)) = symGroupImage
    -- Since centralizer(symGroupImage) = diagonalActionImage, this gives the result
    haveI := symGroupImage_isSemisimpleRing k V n
    haveI := symGroupImage_faithfulSMul k V n hN
    rw [‚Üź h_cent]
    exact (Theorem5_18_1_double_centralizer k (TensorPower k V n) (symGroupImage k V n)).symm
  ¬∑ -- diagonalActionImage = centralizer(symGroupImage)
    exact h_cent.symm

/-- Schur-Weyl duality, part (ii): The symmetric group and diagonal
action subalgebras of End(V^‚äón) are both semisimple.
(Etingof Theorem 5.18.4, part ii) -/
theorem Theorem5_18_4_semisimple
    [CharZero k]
    (hN : n ‚Č§ Module.finrank k V) :
    IsSemisimpleRing (symGroupImage k V n)
    ‚ąß IsSemisimpleRing (diagonalActionImage k V n) := by
  constructor
  ¬∑ exact symGroupImage_isSemisimpleRing k V n
  ¬∑ -- diagonalActionImage = centralizer(symGroupImage)
    -- centralizer of semisimple subalgebra is semisimple
    rw [‚Üź centralizer_symGroupImage_eq_diagonalActionImage
      k V n hN]
    haveI := symGroupImage_isSemisimpleRing k V n
    haveI := symGroupImage_faithfulSMul k V n hN
    exact Theorem5_18_1_commutant_semisimple k (TensorPower k V n) (symGroupImage k V n)

/-- Schur-Weyl duality, part (iii): Decomposition of V^‚äón.

V^‚äón decomposes as a direct sum of tensor products of simple modules:
  V^‚äón ‚ČÖ ‚äē_i S_i ‚äó L_i
where {S_i} are the distinct simple k[S_n]-modules (Specht modules)
appearing in V^‚äón and {L_i} are the corresponding irreducible
polynomial GL(V)-representations.
(Etingof Theorem 5.18.4, part iii) -/
theorem Theorem5_18_4_decomposition
    [CharZero k]
    (hN : n ‚Č§ Module.finrank k V) :
    ‚ąÉ (őĻ : Type) (_ : Fintype őĻ) (_ : DecidableEq őĻ)
      (S : őĻ ‚Üí Type (max u v)) (L : őĻ ‚Üí Type u)
      (_ : ‚ąÄ i, AddCommGroup (S i))
      (_ : ‚ąÄ i, Module k (S i))
      (_ : ‚ąÄ i, AddCommGroup (L i))
      (_ : ‚ąÄ i, Module k (L i)),
      Nonempty (TensorPower k V n ‚ČÉ‚āó[k]
        DirectSum őĻ (fun i => S i ‚äó[k] L i)) := by
  haveI := symGroupImage_isSemisimpleRing k V n
  haveI := symGroupImage_faithfulSMul k V n hN
  obtain ‚ü®őĻ, hőĻ, hőĻ_dec, V', W', hV'_acg, hV'_mod,
    hV'_Amod, hV'_simp, hW'_acg, hW'_mod, ‚ü®e‚ü©‚ü© :=
    Theorem5_18_1_decomposition k
      (TensorPower k V n) (symGroupImage k V n)
  exact ‚ü®őĻ, hőĻ, hőĻ_dec, V', W',
    hV'_acg, hV'_mod, hW'_acg, hW'_mod, ‚ü®e‚ü©‚ü©

/-- Schur-Weyl duality: partition-indexed decomposition of V^‚äón.
This refines `Theorem5_18_4_decomposition` by re-indexing the decomposition
by `Nat.Partition n`. Each summand `S p ‚äó L p` collects the components
from the generic decomposition that are assigned to partition `p`.
(Etingof Theorem 5.18.4, part iii) -/
theorem Theorem5_18_4_partition_decomposition
    [IsAlgClosed k] [CharZero k]
    (hN : n ‚Č§ Module.finrank k V) :
    ‚ąÉ (S : Nat.Partition n ‚Üí Type (max u v))
      (L : Nat.Partition n ‚Üí Type u)
      (_ : ‚ąÄ p, AddCommGroup (S p))
      (_ : ‚ąÄ p, Module k (S p))
      (_ : ‚ąÄ p, AddCommGroup (L p))
      (_ : ‚ąÄ p, Module k (L p)),
      Nonempty (TensorPower k V n ‚ČÉ‚āó[k]
        DirectSum (Nat.Partition n)
          (fun p => S p ‚äó[k] L p)) := by
  -- Use the existing őĻ-indexed decomposition from Theorem 5.18.4(iii)
  obtain ‚ü®őĻ, hőĻ, hőĻ_dec, S', L', hS'_acg, hS'_mod, hL'_acg, hL'_mod, ‚ü®e‚ü©‚ü© :=
    Theorem5_18_4_decomposition k V n hN
  -- Re-index: choose any function f : őĻ ‚Üí Nat.Partition n, then group
  -- summands by fiber. Empty fibers contribute zero modules.
  haveI : Nonempty (Nat.Partition n) :=
    ‚ü®‚ü®Multiset.replicate n 1, fun {i} hi => by
      simp [Multiset.mem_replicate] at hi; omega,
      by simp‚ü©‚ü©
  let f : őĻ ‚Üí Nat.Partition n := fun _ => Classical.arbitrary _
  -- Define S p as the fiber direct sum: ‚äē_{i : f‚ĀĽ¬Ļ(p)} (S' i ‚äó L' i)
  -- Define L p = k (so S p ‚äó k ‚ČÖ S p via TensorProduct.rid)
  let M : őĻ ‚Üí Type (max u v) := fun i => S' i ‚äó[k] L' i
  refine ‚ü®fun p => DirectSum {i : őĻ // f i = p} (fun j => M j.val),
          fun _ => k,
          inferInstance, inferInstance, inferInstance, inferInstance, ‚ü®?_‚ü©‚ü©
  -- Build the equivalence chain:
  -- V‚äó‚ĀŅ ‚ČÉ ‚äē_őĻ M ‚ČÉ ‚äē_{ő£ p, fiber} M ‚ČÉ ‚äē_p (‚äē_fiber M) ‚ČÉ ‚äē_p ((‚äē_fiber M) ‚äó k)
  -- Step 2: re-index ‚äē_őĻ M along the fiber equivalence
  have e‚āā := DirectSum.lequivCongrLeft (R := k)
    (Equiv.sigmaFiberEquiv f).symm (M := M)
  -- Step 3+4: sigma curry then tensor with k
  -- sigmaLcurryEquiv : (R) ‚Üí [Semiring R] ‚Üí {őĻ} ‚Üí {őĪ : őĻ ‚Üí Type} ‚Üí {őī : (i : őĻ) ‚Üí őĪ i ‚Üí Type} ‚Üí
  --   [DecidableEq őĻ] ‚Üí [AddCommMonoid] ‚Üí [Module] ‚Üí
  --   DirectSum (ő£ x, őĪ x) (fun i => őī i.1 i.2) ‚ČÉ‚āó[R]
  --     DirectSum őĻ (fun i => DirectSum (őĪ i) (fun j => őī i j))
  let e‚āÉ := @DirectSum.sigmaLcurryEquiv k _ (Nat.Partition n)
    (fun p => {j : őĻ // f j = p})
    (fun p (j : {j : őĻ // f j = p}) => M j.val)
    _ (fun _ _ => inferInstance) (fun _ _ => inferInstance)
  -- Step 4: tensor with k via TensorProduct.rid
  let e‚āĄ := DFinsupp.mapRange.linearEquiv (R := k)
    (fun p : Nat.Partition n => (TensorProduct.rid k
      (DirectSum {j : őĻ // f j = p} (fun j => M j.val))).symm)
  -- Now compose: V‚äó‚ĀŅ ‚Üí[e] ‚äē_őĻ M ‚Üí[e‚āā] ‚äē_ő£ M ‚Üí[e‚āÉ] ‚äē_p(‚äē_fiber M) ‚Üí[e‚āĄ] ‚äē_p(‚äē_fiber M ‚äó k)
  exact e.trans (e‚āā.trans (e‚āÉ.trans e‚āĄ))

-- Heartbeat bumps match `Theorem5_18_1_bimodule_decomposition`: the deep
-- `Subalgebra ‚Üí Ring ‚Üí Module.End` instance chain plus the `h_eq ‚Ėł` transport
-- across the centralizer equality exceeds the defaults.
set_option maxHeartbeats 1600000 in
set_option synthInstance.maxHeartbeats 800000 in
/-- Schur-Weyl duality, part (iii), bimodule form.

As an `(A ‚äó[k] B)`-module (with `A = symGroupImage k V n` and
`B = diagonalActionImage k V n`), `V^‚äón` decomposes as
  `V^‚äón ‚ČÖ ‚®ĀŠĶĘ SŠĶĘ ‚äó[k] LŠĶĘ`
where the `SŠĶĘ` are pairwise non-isomorphic simple `A`-modules (Specht
modules) and each `LŠĶĘ` is a `B`-module (an irreducible polynomial
`GL(V)`-representation).

This refines `Theorem5_18_4_decomposition` by adding:
* a `Module A`-structure on each `SŠĶĘ` together with `IsSimpleModule`;
* pairwise non-isomorphism of the `SŠĶĘ`;
* a `Module B`-structure on each `LŠĶĘ`.

The `Module B`-structure is obtained via
`Theorem5_18_1_bimodule_decomposition` (which produces a `Module`
action of `centralizer(A)` on `LŠĶĘ`) together with the Schur-Weyl
centralizer identity `centralizer(symGroupImage) = diagonalActionImage`
from `Theorem5_18_4_centralizers`.
(Etingof Theorem 5.18.4, part iii, bimodule form.) -/
theorem Theorem5_18_4_bimodule_decomposition
    [IsAlgClosed k] [CharZero k]
    (hN : n ‚Č§ Module.finrank k V) :
    ‚ąÉ (őĻ : Type) (_ : Fintype őĻ) (_ : DecidableEq őĻ)
      (S : őĻ ‚Üí Type (max u v))
      (_ : ‚ąÄ i, AddCommGroup (S i))
      (_ : ‚ąÄ i, Module k (S i))
      (_ : ‚ąÄ i, Module (symGroupImage k V n) (S i))
      (_ : ‚ąÄ i, IsSimpleModule (symGroupImage k V n) (S i))
      (_ : ‚ąÄ i j, Nonempty (S i ‚ČÉ‚āó[symGroupImage k V n] S j) ‚Üí i = j)
      (_ : ‚ąÄ i, Module.Finite k (S i))
      (L : őĻ ‚Üí Type (max u v)) (_ : ‚ąÄ i, AddCommGroup (L i))
      (_ : ‚ąÄ i, Module k (L i))
      (_ : ‚ąÄ i, Module (diagonalActionImage k V n) (L i)),
      Nonempty (TensorPower k V n ‚ČÉ‚āó[k]
        DirectSum őĻ (fun i => S i ‚äó[k] L i)) := by
  haveI := symGroupImage_isSemisimpleRing k V n
  haveI := symGroupImage_faithfulSMul k V n hN
  obtain ‚ü®őĻ, hőĻ, hőĻ_dec, S', hS'_acg, hS'_mod, hS'_Amod, hS'_simp,
    hS'_dist, hS'_fin, L', hL'_acg, hL'_mod, hL'_Bmod, _hL'_smul, _hL'_fin, ‚ü®e‚ü©‚ü© :=
    Theorem5_18_1_bimodule_decomposition k (TensorPower k V n)
      (symGroupImage k V n)
  -- Transport the `Module ‚Ü•(centralizer(symGroupImage))` structure on each
  -- `L' i` to a `Module ‚Ü•(diagonalActionImage)` structure using the
  -- centralizer identity from `Theorem5_18_4_centralizers` (part ii).
  have h_eq : Subalgebra.centralizer k
      (symGroupImage k V n : Set (Module.End k (TensorPower k V n))) =
        diagonalActionImage k V n :=
    (Theorem5_18_4_centralizers k V n hN).2.symm
  refine ‚ü®őĻ, hőĻ, hőĻ_dec, S', hS'_acg, hS'_mod, hS'_Amod, hS'_simp, hS'_dist,
    hS'_fin, L', hL'_acg, hL'_mod, fun i => h_eq ‚Ėł hL'_Bmod i, ‚ü®e‚ü©‚ü©

