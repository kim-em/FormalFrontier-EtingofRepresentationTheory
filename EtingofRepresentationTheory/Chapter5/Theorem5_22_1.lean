import Mathlib
import EtingofRepresentationTheory.Chapter5.Proposition5_21_1
import EtingofRepresentationTheory.Chapter5.Definition5_12_1
import EtingofRepresentationTheory.Chapter5.Theorem5_18_4

/-!
# Theorem 5.22.1: Weyl Character Formula for GL(V)

## Construction

The Schur module `L_Œª` is the image of the Young symmetrizer `c_Œª` acting
on the tensor power `(k^N)^{‚äón}` where `n = ‚àë Œª·µ¢`. The GL_N(k)-action
on this image comes from the diagonal action `g ‚Ü¶ g‚äóg‚äó‚Ä¶‚äóg`, which
commutes with the symmetric group action (hence with `c_Œª`), so the image
is GL_N-stable.
-/

open MvPolynomial Finset CategoryTheory

noncomputable section

namespace Etingof

/-! ### Weight to partition conversion -/

/-- Convert a weight vector `lam : Fin N ‚Üí ‚Ñï` to a partition of `‚àë i, lam i`. -/
def weightToPartition (N : ‚Ñï) (lam : Fin N ‚Üí ‚Ñï) :
    Nat.Partition (‚àë i, lam i) where
  parts := (Finset.univ.val.map lam).filter (0 < ¬∑)
  parts_pos hi := (Multiset.mem_filter.mp hi).2
  parts_sum := by
    have h_filt : ‚àÄ (s : Multiset ‚Ñï), (s.filter (0 < ¬∑)).sum = s.sum := by
      intro s
      induction s using Multiset.induction with
      | empty => simp
      | cons a s ih =>
        simp only [Multiset.filter_cons]
        split
        ¬∑ simp [Multiset.sum_cons, ih]
        ¬∑ rename_i h; push_neg at h; simp [Nat.le_zero.mp h, ih]
    rw [h_filt]
    simp [Finset.sum]

/-! ### Young symmetrizer over a general field -/

/-- The Young symmetrizer `c_Œª = a_Œª ¬∑ b_Œª` in `k[S_n]`, over a general field `k`. -/
def YoungSymmetrizerK (k : Type*) [CommRing k] (n : ‚Ñï) (la : Nat.Partition n) :
    MonoidAlgebra k (Equiv.Perm (Fin n)) :=
  haveI : DecidablePred (¬∑ ‚àà RowSubgroup n la) := Classical.decPred _
  haveI : DecidablePred (¬∑ ‚àà ColumnSubgroup n la) := Classical.decPred _
  (‚àë g : (RowSubgroup n la), MonoidAlgebra.of k _ g.val) *
  (‚àë g : (ColumnSubgroup n la),
    ((‚Üë(Equiv.Perm.sign g.val) : ‚Ñ§) : k) ‚Ä¢ MonoidAlgebra.of k _ g.val)

/-! ### Young symmetrizer endomorphism on tensor power -/

/-- The Young symmetrizer `c_Œª` lifted to an endomorphism of `V^{‚äón}`. -/
def youngSymEndomorphism (k : Type*) [Field k] (N : ‚Ñï) (lam : Fin N ‚Üí ‚Ñï) :
    Module.End k (TensorPower k (Fin N ‚Üí k) (‚àë i, lam i)) :=
  symGroupAlgHom k (Fin N ‚Üí k) (‚àë i, lam i)
    (YoungSymmetrizerK k (‚àë i, lam i) (weightToPartition N lam))

/-! ### GL_N representation on tensor power -/

/-- The diagonal action of `GL_N(k)` on `V^{‚äón}`: `g` acts as `g ‚äó g ‚äó ‚Ä¶ ‚äó g`.
The representation map sends `g ‚àà GL_N(k)` to the linear endomorphism
`PiTensorProduct.map (fun _ => g.val.mulVecLin)`. -/
def glTensorRep (k : Type*) [Field k] (N n : ‚Ñï) :
    Representation k (Matrix.GeneralLinearGroup (Fin N) k)
      (TensorPower k (Fin N ‚Üí k) n) where
  toFun g := PiTensorProduct.map (fun _ : Fin n => Matrix.mulVecLin (R := k) g.val)
  map_one' := by
    classical
    change PiTensorProduct.map (fun _ : Fin n => Matrix.mulVecLin (R := k) (1 : Matrix _ _ k)) =
      LinearMap.id
    have : (fun _ : Fin n => Matrix.mulVecLin (R := k) (1 : Matrix _ _ k)) =
        (fun _ : Fin n => (LinearMap.id : (Fin N ‚Üí k) ‚Üí‚Çó[k] (Fin N ‚Üí k))) :=
      funext fun _ => Matrix.mulVecLin_one
    rw [this, PiTensorProduct.map_id]
  map_mul' g‚ÇÅ g‚ÇÇ := by
    classical
    change PiTensorProduct.map (fun _ : Fin n => Matrix.mulVecLin (R := k) (g‚ÇÅ.val * g‚ÇÇ.val)) =
      (PiTensorProduct.map (fun _ : Fin n => Matrix.mulVecLin g‚ÇÅ.val)) ‚àò‚Çó
      (PiTensorProduct.map (fun _ : Fin n => Matrix.mulVecLin g‚ÇÇ.val))
    have : (fun _ : Fin n => Matrix.mulVecLin (R := k) (g‚ÇÅ.val * g‚ÇÇ.val)) =
        (fun _ : Fin n => (Matrix.mulVecLin g‚ÇÅ.val).comp (Matrix.mulVecLin g‚ÇÇ.val)) :=
      funext fun _ => Matrix.mulVecLin_mul g‚ÇÅ.val g‚ÇÇ.val
    rw [this, PiTensorProduct.map_comp]

/-! ### GL action commutes with Young symmetrizer -/

/-- The GL_N diagonal action commutes with the Young symmetrizer endomorphism.
The GL action commutes with each permutation operator œÉ ‚àà S_n by
`symGroupAction_comm_diagonalAction`, hence with any element of k[S_n],
hence with the Young symmetrizer. -/
theorem glTensor_comm_youngSym (k : Type*) [Field k] (N : ‚Ñï) (lam : Fin N ‚Üí ‚Ñï)
    (g : Matrix.GeneralLinearGroup (Fin N) k) :
    glTensorRep k N (‚àë i, lam i) g ‚àò‚Çó youngSymEndomorphism k N lam =
    youngSymEndomorphism k N lam ‚àò‚Çó glTensorRep k N (‚àë i, lam i) g := by
  set n := ‚àë i, lam i
  set V := Fin N ‚Üí k
  set f : V ‚Üí‚Çó[k] V := Matrix.mulVecLin g.val
  -- The Young symmetrizer endomorphism is in symGroupImage (range of symGroupAlgHom)
  have h_sym : (youngSymEndomorphism k N lam : Module.End k (TensorPower k V n)) ‚àà
      (symGroupImage k V n : Set (Module.End k (TensorPower k V n))) := by
    rw [‚Üê symGroupAlgHom_range k V n]
    exact ‚ü®_, rfl‚ü©
  -- The GL tensor action is in diagonalActionImage (generated by PiTensorProduct.map f)
  have h_diag : (glTensorRep k N n g : Module.End k (TensorPower k V n)) ‚àà
      (diagonalActionImage k V n : Set (Module.End k (TensorPower k V n))) := by
    apply Algebra.subset_adjoin
    exact ‚ü®f, rfl‚ü©
  -- By diagonalActionImage_le_centralizer_symGroupImage, diagonal elements
  -- commute with all symmetric group elements
  have hcent := diagonalActionImage_le_centralizer_symGroupImage k V n h_diag
  rw [Subalgebra.mem_centralizer_iff] at hcent
  -- Get commutativity: young * g_tensor = g_tensor * young
  exact (hcent _ h_sym).symm

/-- The image of the Young symmetrizer is GL_N-stable. -/
theorem glTensorRep_mem_range (k : Type*) [Field k] (N : ‚Ñï) (lam : Fin N ‚Üí ‚Ñï)
    (g : Matrix.GeneralLinearGroup (Fin N) k) (v : TensorPower k (Fin N ‚Üí k) (‚àë i, lam i))
    (hv : v ‚àà LinearMap.range (youngSymEndomorphism k N lam)) :
    (glTensorRep k N (‚àë i, lam i) g) v ‚àà LinearMap.range (youngSymEndomorphism k N lam) := by
  obtain ‚ü®w, rfl‚ü© := hv
  exact ‚ü®(glTensorRep k N (‚àë i, lam i) g) w,
    (LinearMap.ext_iff.mp (glTensor_comm_youngSym k N lam g) w).symm‚ü©

/-! ### Schur module construction -/

/-- The Schur module as a submodule of `V^{‚äón}`: the image of the Young symmetrizer. -/
def SchurModuleSubmodule (k : Type*) [Field k] (N : ‚Ñï) (lam : Fin N ‚Üí ‚Ñï) :
    Submodule k (TensorPower k (Fin N ‚Üí k) (‚àë i, lam i)) :=
  LinearMap.range (youngSymEndomorphism k N lam)

/-- The GL_N(k) representation restricted to the Schur module submodule.
The representation sends `g` to the restriction of `g^{‚äón}` to the image
of the Young symmetrizer, which is stable because GL_N commutes with S_n. -/
def schurModuleRep (k : Type*) [Field k] (N : ‚Ñï) (lam : Fin N ‚Üí ‚Ñï) :
    Representation k (Matrix.GeneralLinearGroup (Fin N) k)
      (SchurModuleSubmodule k N lam) where
  toFun g := (glTensorRep k N (‚àë i, lam i) g).restrict
    (p := SchurModuleSubmodule k N lam) (q := SchurModuleSubmodule k N lam)
    (fun v hv => glTensorRep_mem_range k N lam g v hv)
  map_one' := by
    ext ‚ü®v, hv‚ü©
    simp only [LinearMap.restrict_coe_apply]
    exact LinearMap.ext_iff.mp (map_one (glTensorRep k N _)) v
  map_mul' g‚ÇÅ g‚ÇÇ := by
    ext ‚ü®v, hv‚ü©
    -- After ext, both sides coerce to elements of TensorPower via restrict_coe_apply
    have h_mul := LinearMap.ext_iff.mp (map_mul (glTensorRep k N (‚àë i, lam i)) g‚ÇÅ g‚ÇÇ) v
    -- h_mul : (glTensorRep (g‚ÇÅ * g‚ÇÇ)) v = (glTensorRep g‚ÇÅ * glTensorRep g‚ÇÇ) v
    --       = (glTensorRep g‚ÇÅ) ((glTensorRep g‚ÇÇ) v)
    -- Goal: coercion of restrict(g‚ÇÅ*g‚ÇÇ) = coercion of (restrict(g‚ÇÅ) * restrict(g‚ÇÇ))
    simp only [LinearMap.restrict_coe_apply, Module.End.mul_apply] at h_mul ‚ä¢
    exact h_mul

/-- The Schur module submodule is finite-dimensional. -/
instance schurModuleSubmodule_finite (k : Type*) [Field k] (N : ‚Ñï) (lam : Fin N ‚Üí ‚Ñï) :
    Module.Finite k (SchurModuleSubmodule k N lam) :=
  inferInstance

/-- The Schur module `L_Œª`: the irreducible polynomial representation of `GL_N(k)`
with highest weight `Œª = (Œª‚ÇÅ ‚â• ‚ãØ ‚â• Œª_N ‚â• 0)`.

Constructed as the image of the Young symmetrizer `c_Œª` acting on the tensor
power `(k^N)^{‚äón}` where `n = ‚àë Œª·µ¢`. The `GL_N(k)`-action is the restriction
of the diagonal action `g ‚Ü¶ g^{‚äón}`, which commutes with the `S_n`-action
(and hence with `c_Œª`), making the image `GL_N`-stable. -/
def SchurModule (k : Type*) [Field k] [IsAlgClosed k] (N : ‚Ñï) (lam : Fin N ‚Üí ‚Ñï) :
    FDRep k (Matrix.GeneralLinearGroup (Fin N) k) :=
  FDRep.of (schurModuleRep k N lam)

/-! ### Diagonal torus and weight spaces -/

/-- The diagonal matrix in `GL_N(k)` with `t` at position `(i,i)` and `1` elsewhere.
This embeds a single coordinate of the maximal torus `(k√ó)^N ‚Ü™ GL_N(k)`. -/
noncomputable def diagUnit (k : Type*) [Field k] (N : ‚Ñï) (i : Fin N) (t : kÀ£) :
    Matrix.GeneralLinearGroup (Fin N) k where
  val := Matrix.diagonal (Function.update 1 i (t : k))
  inv := Matrix.diagonal (Function.update 1 i ((t‚Åª¬π : kÀ£) : k))
  val_inv := by
    rw [Matrix.diagonal_mul_diagonal, ‚Üê Matrix.diagonal_one]
    congr 1; ext j
    by_cases h : j = i
    ¬∑ subst h; simp [Units.val_inv_eq_inv_val]
    ¬∑ simp [Function.update_of_ne h]
  inv_val := by
    rw [Matrix.diagonal_mul_diagonal, ‚Üê Matrix.diagonal_one]
    congr 1; ext j
    by_cases h : j = i
    ¬∑ subst h; simp [Units.val_inv_eq_inv_val]
    ¬∑ simp [Function.update_of_ne h]

/-- The weight space `M_Œº` for weight `Œº : Fin N ‚Üí ‚Ñï` in a `GL_N(k)`-representation `M`.
This is the subspace of `M` where the diagonal matrix with `t` at position `i`
acts as scalar multiplication by `t ^ Œº i`, for each `i` and all `t ‚àà k√ó`. -/
noncomputable def glWeightSpace (k : Type*) [Field k] [IsAlgClosed k] (N : ‚Ñï)
    (M : FDRep k (Matrix.GeneralLinearGroup (Fin N) k))
    (Œº : Fin N ‚Üí ‚Ñï) : Submodule k M :=
  ‚®Ö (i : Fin N) (t : kÀ£),
    LinearMap.ker (M.œÅ (diagUnit k N i t) - ((t : k) ^ Œº i) ‚Ä¢ LinearMap.id)

/-! ### Diagonal matrices commute -/

/-- Diagonal matrices with entries modified at different positions commute. -/
theorem diagUnit_comm (k : Type*) [Field k] (N : ‚Ñï) (i‚ÇÅ : Fin N) (t‚ÇÅ : kÀ£)
    (i‚ÇÇ : Fin N) (t‚ÇÇ : kÀ£) :
    diagUnit k N i‚ÇÅ t‚ÇÅ * diagUnit k N i‚ÇÇ t‚ÇÇ = diagUnit k N i‚ÇÇ t‚ÇÇ * diagUnit k N i‚ÇÅ t‚ÇÅ := by
  ext : 1
  change (diagUnit k N i‚ÇÅ t‚ÇÅ).val * (diagUnit k N i‚ÇÇ t‚ÇÇ).val =
    (diagUnit k N i‚ÇÇ t‚ÇÇ).val * (diagUnit k N i‚ÇÅ t‚ÇÅ).val
  simp only [diagUnit, Matrix.diagonal_mul_diagonal, mul_comm]

/-- The representation of two diagUnit elements commutes. -/
theorem rep_diagUnit_commute (k : Type*) [Field k] [IsAlgClosed k] (N : ‚Ñï)
    (M : FDRep k (Matrix.GeneralLinearGroup (Fin N) k))
    (i‚ÇÅ : Fin N) (t‚ÇÅ : kÀ£) (i‚ÇÇ : Fin N) (t‚ÇÇ : kÀ£) :
    Commute (M.œÅ (diagUnit k N i‚ÇÅ t‚ÇÅ)) (M.œÅ (diagUnit k N i‚ÇÇ t‚ÇÇ)) := by
  change M.œÅ (diagUnit k N i‚ÇÅ t‚ÇÅ) * M.œÅ (diagUnit k N i‚ÇÇ t‚ÇÇ) =
    M.œÅ (diagUnit k N i‚ÇÇ t‚ÇÇ) * M.œÅ (diagUnit k N i‚ÇÅ t‚ÇÅ)
  rw [‚Üê map_mul, ‚Üê map_mul, diagUnit_comm]

/-! ### Weight space is contained in eigenspace -/

/-- The weight space is contained in the maximal generalized eigenspace of each
torus operator. Proved by extracting the (i, t) component from the iInf. -/
theorem glWeightSpace_le_maxGenEigenspace (k : Type*) [Field k] [IsAlgClosed k] (N : ‚Ñï)
    (M : FDRep k (Matrix.GeneralLinearGroup (Fin N) k))
    (Œº : Fin N ‚Üí ‚Ñï) (i : Fin N) (t : kÀ£) :
    glWeightSpace k N M Œº ‚â§
      Module.End.maxGenEigenspace (M.œÅ (diagUnit k N i t)) ((t : k) ^ Œº i) := by
  intro v hv
  -- Extract the (i, t) component: v ‚àà ker(œÅ(diagUnit i t) - t^(Œº i) ‚Ä¢ id)
  have h1 : glWeightSpace k N M Œº ‚â§ ‚®Ö (s : kÀ£),
      LinearMap.ker (M.œÅ (diagUnit k N i s) - ((s : k) ^ Œº i) ‚Ä¢ LinearMap.id) :=
    iInf_le _ i
  have h2 : ‚®Ö (s : kÀ£),
      LinearMap.ker (M.œÅ (diagUnit k N i s) - ((s : k) ^ Œº i) ‚Ä¢ LinearMap.id) ‚â§
      LinearMap.ker (M.œÅ (diagUnit k N i t) - ((t : k) ^ Œº i) ‚Ä¢ LinearMap.id) :=
    iInf_le _ t
  have hker := LinearMap.mem_ker.mp (h2 (h1 hv))
  -- hker says (œÅ(diagUnit i t) - t^(Œº i) ‚Ä¢ id) v = 0, so œÅ(diagUnit i t) v = t^(Œº i) ‚Ä¢ v
  have hev : (M.œÅ (diagUnit k N i t)) v = ((t : k) ^ Œº i) ‚Ä¢ v := by
    rwa [LinearMap.sub_apply, LinearMap.smul_apply, LinearMap.id_apply, sub_eq_zero] at hker
  -- This means v is an eigenvector, hence in the maxGenEigenspace
  exact Module.End.eigenspace_le_maxGenEigenspace (Module.End.mem_eigenspace_iff.mpr hev)

/-! ### Finiteness of weight support -/

/-- In an algebraically closed field (hence infinite), for any n ‚â• 1 there exists
a unit t such that t^n ‚âÝ 1. -/
theorem exists_unit_pow_ne_one (k : Type*) [Field k] [IsAlgClosed k] (n : ‚Ñï) (hn : n ‚â• 1) :
    ‚àÉ t : kÀ£, (t : k) ^ n ‚âÝ 1 := by
  by_contra h; push_neg at h
  -- Every nonzero element of k is a root of X^n - C 1
  have hp_ne : (Polynomial.X ^ n - Polynomial.C (1 : k)) ‚âÝ 0 :=
    Polynomial.X_pow_sub_C_ne_zero (by omega) 1
  -- The roots of X^n - 1 form a finite set
  have hfin : {a : k | a ^ n = 1}.Finite := by
    apply ((Polynomial.X ^ n - Polynomial.C (1 : k)).rootSet_finite k).subset
    intro a (ha : a ^ n = 1)
    rw [Polynomial.mem_rootSet]
    exact ‚ü®hp_ne, by simp [ha]‚ü©
  -- But every nonzero element of k satisfies x^n = 1
  have hsub : {a : k | a ‚âÝ 0} ‚äÜ {a : k | a ^ n = 1} :=
    fun a ha => by simpa using h (Units.mk0 a ha)
  -- The set of nonzero elements is infinite (k is algebraically closed hence infinite)
  have hinf : Set.Infinite {a : k | a ‚âÝ 0} := by
    rw [show {a : k | a ‚âÝ 0} = ({0} : Set k)·∂ú from by ext; simp]
    exact (Set.finite_singleton _).infinite_compl
  exact hinf.not_finite (hfin.subset hsub)

/-- In an algebraically closed (hence infinite) field, distinct natural number exponents
give distinct power functions: if a ‚âÝ b, there exists t ‚àà kÀ£ with t^a ‚âÝ t^b. -/
theorem exists_unit_pow_ne (k : Type*) [Field k] [IsAlgClosed k] {a b : ‚Ñï} (hab : a ‚âÝ b) :
    ‚àÉ t : kÀ£, (t : k) ^ a ‚âÝ (t : k) ^ b := by
  -- Reduce to the case a > b
  suffices ‚àÄ {a b : ‚Ñï}, a > b ‚Üí ‚àÉ t : kÀ£, (t : k) ^ a ‚âÝ (t : k) ^ b from by
    rcases Nat.lt_or_gt_of_ne hab with h | h
    ¬∑ obtain ‚ü®t, ht‚ü© := this h; exact ‚ü®t, ht.symm‚ü©
    ¬∑ exact this h
  intro a b h
  obtain ‚ü®t, ht‚ü© := exists_unit_pow_ne_one k (a - b) (by omega)
  refine ‚ü®t, fun heq => ht ?_‚ü©
  have hne : (t : k) ^ b ‚âÝ 0 := pow_ne_zero _ (Units.ne_zero t)
  have : (t : k) ^ (a - b) * (t : k) ^ b = 1 * (t : k) ^ b := by
    rw [‚Üê pow_add, Nat.sub_add_cancel h.le, heq, one_mul]
  exact mul_right_cancel‚ÇÄ hne this

/-- The set of weights with nonzero weight space is finite for any finite-dimensional
`GL_N(k)`-representation. -/
theorem glWeightSpace_finite_support (k : Type*) [Field k] [IsAlgClosed k] (N : ‚Ñï)
    (M : FDRep k (Matrix.GeneralLinearGroup (Fin N) k)) :
    { Œº : Fin N ‚Üí‚ÇÄ ‚Ñï | glWeightSpace k N M (fun i => Œº i) ‚âÝ ‚ä• }.Finite := by
  -- Define the family of operators indexed by (Fin N √ó kÀ£)
  set f : Fin N √ó kÀ£ ‚Üí Module.End k M := fun p => M.œÅ (diagUnit k N p.1 p.2) with hf_def
  -- The operators commute, so they satisfy the MapsTo condition
  have h_comm : ‚àÄ (p‚ÇÅ p‚ÇÇ : Fin N √ó kÀ£), Commute (f p‚ÇÅ) (f p‚ÇÇ) :=
    fun p‚ÇÅ p‚ÇÇ => rep_diagUnit_commute k N M p‚ÇÅ.1 p‚ÇÅ.2 p‚ÇÇ.1 p‚ÇÇ.2
  have h_mapsTo : ‚àÄ (p‚ÇÅ p‚ÇÇ : Fin N √ó kÀ£) (œÜ : k),
      Set.MapsTo (f p‚ÇÅ)
        ((f p‚ÇÇ).maxGenEigenspace œÜ) ((f p‚ÇÇ).maxGenEigenspace œÜ) :=
    fun p‚ÇÅ p‚ÇÇ œÜ => Module.End.mapsTo_maxGenEigenspace_of_comm (h_comm p‚ÇÇ p‚ÇÅ) œÜ
  -- By Pi.lean, the simultaneous maximal generalized eigenspaces are independent
  have h_indep := Module.End.independent_iInf_maxGenEigenspace_of_forall_mapsTo f h_mapsTo
  -- By Noetherian, only finitely many are nonzero
  have h_fin := Submodule.finite_ne_bot_of_iSupIndep h_indep
  -- The weight space for Œº is contained in the simultaneous maxGenEigenspace for œá_Œº
  -- where œá_Œº(i, t) = t^(Œº i)
  -- Define the eigenvalue map
  set œá : (Fin N ‚Üí‚ÇÄ ‚Ñï) ‚Üí (Fin N √ó kÀ£ ‚Üí k) :=
    fun Œº p => (p.2 : k) ^ (Œº p.1) with hœá_def
  -- Show the map is injective
  have h_inj : Function.Injective œá := by
    intro Œº‚ÇÅ Œº‚ÇÇ heq
    ext i
    by_contra hi
    obtain ‚ü®t, ht‚ü© := exists_unit_pow_ne k hi
    exact ht (congr_fun heq (i, t))
  -- Show glWeightSpace Œº ‚â§ ‚®Ö p, maxGenEigenspace(f p, œá Œº p)
  have h_le : ‚àÄ (Œº : Fin N ‚Üí‚ÇÄ ‚Ñï),
      glWeightSpace k N M (fun i => Œº i) ‚â§
        ‚®Ö (p : Fin N √ó kÀ£), (f p).maxGenEigenspace (œá Œº p) := by
    intro Œº
    apply le_iInf
    intro ‚ü®i, t‚ü©
    exact glWeightSpace_le_maxGenEigenspace k N M (fun j => Œº j) i t
  -- If glWeightSpace Œº ‚âÝ ‚ä•, then the simultaneous maxGenEigenspace is also ‚âÝ ‚ä•
  refine (h_fin.preimage h_inj.injOn).subset ?_
  intro Œº hŒº
  simp only [Set.mem_setOf_eq] at hŒº
  simp only [Set.mem_preimage, Set.mem_setOf_eq]
  exact fun h => hŒº (eq_bot_iff.mpr (h ‚ñ∏ h_le Œº))

/-! ### Formal character -/

/-- The formal character of a finite-dimensional polynomial `GL_N(k)`-representation,
as a polynomial in `N` variables over `‚Ñö`.

For a representation `M`, the formal character is `‚àë_Œº (dim M_Œº) ¬∑ x^Œº` where
`M_Œº` is the weight space for weight `Œº` under the diagonal torus action.
The sum ranges over the finitely many weights with nonzero weight space. -/
noncomputable def formalCharacter (k : Type*) [Field k] [IsAlgClosed k] (N : ‚Ñï)
    (M : FDRep k (Matrix.GeneralLinearGroup (Fin N) k)) :
    MvPolynomial (Fin N) ‚Ñö :=
  have hfin : { Œº : Fin N ‚Üí‚ÇÄ ‚Ñï |
      glWeightSpace k N M (fun i => Œº i) ‚âÝ ‚ä• }.Finite :=
    glWeightSpace_finite_support k N M
  hfin.toFinset.sum fun Œº =>
    (Module.finrank k (glWeightSpace k N M (fun i => Œº i)) : ‚Ñö) ‚Ä¢
      MvPolynomial.monomial Œº 1

variable (k : Type*) [Field k] [IsAlgClosed k]

/-! ### Coefficient extraction for formal character -/

/-- The coefficient of `x^Œº` in the formal character equals the dimension of the weight space. -/
theorem formalCharacter_coeff (N : ‚Ñï)
    (M : FDRep k (Matrix.GeneralLinearGroup (Fin N) k))
    (Œº : Fin N ‚Üí‚ÇÄ ‚Ñï) :
    (formalCharacter k N M).coeff Œº =
      (Module.finrank k (glWeightSpace k N M (fun i => Œº i)) : ‚Ñö) := by
  unfold formalCharacter
  have key : ‚àÄ (S : Finset (Fin N ‚Üí‚ÇÄ ‚Ñï)) (c : (Fin N ‚Üí‚ÇÄ ‚Ñï) ‚Üí ‚Ñö),
      (S.sum fun ŒΩ => c ŒΩ ‚Ä¢ MvPolynomial.monomial ŒΩ (1 : ‚Ñö)).coeff Œº =
        if Œº ‚àà S then c Œº else 0 := by
    intro S c
    simp only [MvPolynomial.coeff_sum]
    simp_rw [MvPolynomial.coeff_smul, MvPolynomial.coeff_monomial, smul_eq_mul,
      mul_ite, mul_one, mul_zero]
    split_ifs with h
    ¬∑ rw [Finset.sum_eq_single Œº]
      ¬∑ simp
      ¬∑ intro ŒΩ _ hne; exact if_neg hne
      ¬∑ intro h'; exact absurd h h'
    ¬∑ exact Finset.sum_eq_zero fun ŒΩ hŒΩ => by
        rw [if_neg]; exact fun heq => h (heq ‚ñ∏ hŒΩ)
  rw [key]
  split_ifs with hmem
  ¬∑ rfl
  ¬∑ have hbot : glWeightSpace k N M (fun i => Œº i) = ‚ä• := by
      by_contra h
      exact hmem ((glWeightSpace_finite_support k N M).mem_toFinset.mpr h)
    rw [hbot]; simp

/-! ### Weight multiplicity equals Schur polynomial coefficient -/

/-- **Key helper**: The dimension of the weight space for weight `Œº` in the Schur module `L_Œª`
equals the coefficient of `x^Œº` in the Schur polynomial `S_Œª`.

This is the core content of the Weyl character formula at the coefficient level:
`dim(L_Œª)_Œº = [x^Œº] S_Œª(x)`. -/
theorem schurModule_weight_eq_schurPoly_coeff
    (N : ‚Ñï) (lam : Fin N ‚Üí ‚Ñï) (hlam : Antitone lam)
    (Œº : Fin N ‚Üí‚ÇÄ ‚Ñï) :
    (Module.finrank k (glWeightSpace k N (SchurModule k N lam) (fun i => Œº i)) : ‚Ñö) =
      (schurPoly N lam).coeff Œº := by
  sorry

/-- **Weyl character formula for GL(V)**: the formal character of the Schur module
`L_Œª` equals the Schur polynomial `S_Œª(x‚ÇÅ, ‚Ä¶, x_N)`.
(Etingof Theorem 5.22.1) -/
theorem Theorem5_22_1
    (N : ‚Ñï) (lam : Fin N ‚Üí ‚Ñï) (hlam : Antitone lam) :
    formalCharacter k N (SchurModule k N lam) = schurPoly N lam := by
  ext Œº
  rw [formalCharacter_coeff, schurModule_weight_eq_schurPoly_coeff k N lam hlam]

end Etingof
