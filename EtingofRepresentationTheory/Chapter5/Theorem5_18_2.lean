import Mathlib
import EtingofRepresentationTheory.Chapter5.Lemma5_18_3

/-!
# Theorem 5.18.2: End_A(E) as Image of Universal Enveloping Algebra

The algebra End_A(E), where A = Im(‚Ąā[S_n] ‚Üí End(V^‚äón)), equals the image of
U(gl(V)) in End(V^‚äón). It is generated by elements of the form:

  őĒ_n(b) = b‚äó1‚äó...‚äó1 + 1‚äób‚äó...‚äó1 + ... + 1‚äó...‚äó1‚äób

for b ‚ąą gl(V). This connects the centralizer of the symmetric group action
to the Lie algebra action.

## Mathlib correspondence

- `UniversalEnvelopingAlgebra R L` for U(gl(V))
- `PiTensorProduct` / `TensorPower` for V^‚äón
- `Subalgebra.centralizer` for the centralizer
- `AlgHom.range` for the image subalgebra
-/

open scoped TensorProduct

namespace Etingof.Theorem5_18_2

variable (k : Type*) [Field k]
  (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
  (n : ‚Ąē)

/-- The n-th tensor power V^‚äón. -/
abbrev TnsPow := ‚®ā[k] (_ : Fin n), V

/-- The diagonal Lie algebra action of gl(V) on V^‚äón.
Sends b ‚ąą gl(V) = End_k(V) to őĒ_n(b) = ő£ŠĶĘ (1 ‚äó ... ‚äó b ‚äó ... ‚äó 1),
where b appears in position i and identity elsewhere. -/
noncomputable def diagonalLieAction :
    Module.End k V ‚Üí‚āó‚ĀÖk‚ĀÜ Module.End k (TnsPow k V n) where
  toLinearMap :=
    { toFun := fun b => ‚ąĎ i : Fin n,
        PiTensorProduct.map (fun j => if j = i then b else LinearMap.id)
      map_add' := by
        intro b‚āĀ b‚āā
        have key : ‚ąÄ (i : Fin n) (b : Module.End k V),
            (fun j => if j = i then b else LinearMap.id) =
            Function.update (fun _ => LinearMap.id) i b := by
          intro i b; ext j; simp [Function.update, eq_comm]
        simp_rw [key]
        rw [‚Üź Finset.sum_add_distrib]
        congr 1; ext i
        rw [PiTensorProduct.map_update_add]
      map_smul' := by
        intro c b
        have key : ‚ąÄ (i : Fin n) (b : Module.End k V),
            (fun j => if j = i then b else LinearMap.id) =
            Function.update (fun _ => LinearMap.id) i b := by
          intro i b; ext j; simp [Function.update, eq_comm]
        simp_rw [key]
        rw [show RingHom.id k c = c from rfl, Finset.smul_sum]
        congr 1; ext i
        rw [PiTensorProduct.map_update_smul] }
  map_lie' := by
    intro b‚āĀ b‚āā
    have key : ‚ąÄ (i : Fin n) (b : Module.End k V),
        (fun j => if j = i then b else LinearMap.id) =
        Function.update (fun _ => LinearMap.id) i b := by
      intro i b; ext j; simp [Function.update, eq_comm]
    simp_rw [key]
    simp only [LieRing.of_associative_ring_bracket]
    -- LHS: ‚ąĎŠĶĘ map(őīŠĶĘ(b‚āĀ*b‚āā - b‚āā*b‚āĀ))
    -- Step 1: Reduce to ‚ąĎŠĶĘ (map(őīŠĶĘ(b‚āĀ)) * map(őīŠĶĘ(b‚āā)) - map(őīŠĶĘ(b‚āā)) * map(őīŠĶĘ(b‚āĀ)))
    -- Helper: map_mul for our specific type family
    set őī := fun (i : Fin n) (b : Module.End k V) =>
      PiTensorProduct.map (R := k) (s := fun _ => V) (t := fun _ => V)
        (Function.update (fun _ => LinearMap.id) i b) with hőī
    -- Step 1: őī i b‚āĀ * őī j b‚āā = őī of composed updates (via map_mul)
    have mul_eq : ‚ąÄ (i j : Fin n) (a b : Module.End k V),
        őī i a * őī j b = PiTensorProduct.map
          (fun l => Function.update (fun _ => LinearMap.id) i a l *
                    Function.update (fun _ => LinearMap.id) j b l) := by
      intro i j a b; exact (PiTensorProduct.map_mul _ _).symm
    -- Helper: őī respects sub (from multilinear structure)
    have őī_sub : ‚ąÄ (i : Fin n) (a b : Module.End k V),
        őī i (a - b) = őī i a - őī i b := by
      intro i a b
      simp only [hőī]
      exact (PiTensorProduct.mapMultilinear (R := k) (s := fun _ => V)
        (t := fun _ => V)).map_update_sub (fun _ => LinearMap.id) i a b
    -- Helper: őī preserves mul (update id i (a*b) = (update id i a) * (update id i b) pointwise)
    have őī_mul : ‚ąÄ (i : Fin n) (a b : Module.End k V),
        őī i (a * b) = őī i a * őī i b := by
      intro i a b
      simp only [hőī, ‚Üź PiTensorProduct.map_mul]
      congr 1; funext l
      by_cases h : l = i <;>
        simp [Function.update, h, Module.End.mul_eq_comp, LinearMap.comp_id]
    -- Step 2: Each LHS summand equals diagonal term
    have lhs_eq : ‚ąÄ i : Fin n,
        őī i (b‚āĀ * b‚āā - b‚āā * b‚āĀ) = őī i b‚āĀ * őī i b‚āā - őī i b‚āā * őī i b‚āĀ := by
      intro i; rw [őī_sub, őī_mul, őī_mul]
    rw [Finset.sum_congr rfl (fun i _ => lhs_eq i)]
    -- Step 3: Cross-terms (i ‚Č† j) commute
    have comm : ‚ąÄ i j : Fin n, i ‚Č† j ‚Üí őī i b‚āĀ * őī j b‚āā = őī j b‚āā * őī i b‚āĀ := by
      intro i j hij
      simp only [hőī, ‚Üź PiTensorProduct.map_mul]
      congr 1; funext l
      by_cases hi : l = i <;> by_cases hj : l = j <;>
        simp [Function.update, hi, hj, hij, Ne.symm hij,
          Module.End.mul_eq_comp, LinearMap.comp_id, LinearMap.id_comp]
    -- Step 4: Expand RHS to double sum, show cross-terms vanish
    rw [Finset.sum_mul_sum, Finset.sum_mul_sum]
    rw [Finset.sum_comm (f := fun j i => őī j b‚āā * őī i b‚āĀ)]
    rw [‚Üź Finset.sum_sub_distrib]
    simp_rw [‚Üź Finset.sum_sub_distrib]
    -- ‚ąĎŠĶĘ‚ąĎ‚Īľ (őīŠĶĘb‚āĀ*őī‚Īľb‚āā - őī‚Īľb‚āā*őīŠĶĘb‚āĀ). Cross-terms (i‚Č†j) vanish.
    apply Finset.sum_congr rfl; intro i _
    symm
    exact Finset.sum_eq_single i
      (fun j _ hji => sub_eq_zero.mpr (comm i j hji.symm))
      (fun h => absurd (Finset.mem_univ _) h)

/-- The algebra homomorphism from U(gl(V)) to End(V^‚äón) induced by the
diagonal Lie algebra action. By the universal property, the Lie algebra
morphism gl(V) ‚Üí‚āó‚ĀÖk‚ĀÜ End(V^‚äón) lifts uniquely to an algebra map. -/
noncomputable def universalEnvelopingToEnd :
    UniversalEnvelopingAlgebra k (Module.End k V) ‚Üí‚āź[k]
      Module.End k (TnsPow k V n) :=
  UniversalEnvelopingAlgebra.lift k (diagonalLieAction k V n)

/-- The image of k[S_n] in End(V^‚äón), defined as the subalgebra
generated by the symmetric group action (permuting tensor factors). -/
noncomputable def symGroupImage :
    Subalgebra k (Module.End k (TnsPow k V n)) :=
  Algebra.adjoin k (Set.range fun (ŌÉ : Equiv.Perm (Fin n)) =>
    (PiTensorProduct.reindex k (fun _ => V) ŌÉ).toLinearMap)

omit [Module.Finite k V] in
/-- The diagonal Lie action of b ‚ąą gl(V) commutes with permutation of tensor factors. -/
private lemma diagonalLieAction_commutes_reindex (b : Module.End k V)
    (ŌÉ : Equiv.Perm (Fin n)) :
    diagonalLieAction k V n b *
      (PiTensorProduct.reindex k (fun _ : Fin n => V) ŌÉ).toLinearMap =
    (PiTensorProduct.reindex k (fun _ : Fin n => V) ŌÉ).toLinearMap *
      diagonalLieAction k V n b := by
  simp only [diagonalLieAction, LieHom.coe_mk]
  rw [Finset.sum_mul, Finset.mul_sum]
  apply Finset.sum_nbij ŌÉ.symm
  ¬∑ exact fun _ _ => Finset.mem_univ _
  ¬∑ exact ŌÉ.symm.injective.injOn
  ¬∑ exact fun i _ => ‚ü®ŌÉ i, by simp, ŌÉ.symm_apply_apply i‚ü©
  ¬∑ intro i _
    rw [Module.End.mul_eq_comp, Module.End.mul_eq_comp]
    -- Goal: map(őīŠĶĘ b) ‚ąė‚āó reindex ŌÉ = reindex ŌÉ ‚ąė‚āó map(őī_{ŌÉ‚ĀĽ¬Ļ i} b)
    -- map_comp_reindex_eq with f = őī_{ŌÉ‚ĀĽ¬Ļ i} b gives the result
    -- since (őī_{ŌÉ‚ĀĽ¬Ļ i} b)(ŌÉ‚ĀĽ¬Ļ j) = őīŠĶĘ b j by injectivity
    rw [‚Üź PiTensorProduct.map_comp_reindex_eq]
    congr 1; congr 1; funext j
    simp

/-- The centralizer of ‚Ąā[S_n] acting on V^‚äón is the image of U(gl(V)).

The centralizer End_{‚Ąā[S_n]}(V^‚äón) ‚ÄĒ the subalgebra of End(V^‚äón) commuting
with every permutation operator ‚ÄĒ equals the image of the natural algebra
map U(gl(V)) ‚Üí End(V^‚äón) induced by the diagonal Lie action
b ‚Ü¶ őĒ_n(b) = ő£ŠĶĘ (1 ‚äó ... ‚äó b ‚äó ... ‚äó 1).

(Etingof Theorem 5.18.2) -/
theorem centralizer_eq_universalEnvelopingImage [CharZero k] :
    Subalgebra.centralizer k
      (symGroupImage k V n : Set (Module.End k (TnsPow k V n))) =
    (universalEnvelopingToEnd k V n).range := by
  apply le_antisymm
  ¬∑ -- (‚äÜ) centralizer ‚Č§ range: textbook proof (Etingof 5.18.2)
    -- B = S^n End(V) by definition, generated by őĒ_n(b) by Lemma 5.18.3(ii).
    -- Step 1: centralizer of S_n in End(V^‚äón) ‚äÜ S^n End(V)
    -- (the full diagonal subalgebra generated by f ‚äó f ‚äó ... ‚äó f)
    have h_cent_full : Subalgebra.centralizer k
        (symGroupImage k V n : Set (Module.End k (TnsPow k V n))) ‚Č§
        Lemma5_18_3.fullDiagonalSubalgebra k V n := by
      -- Requires the algebra isomorphism End(V^‚äón) ‚ČÖ End(V)^‚äón (not in Mathlib).
      -- Under this iso, S_n acts by permuting tensor factors of End(V)^‚äón,
      -- and the centralizer = S_n-fixed points = S^n End(V) = fullDiagonalSubalgebra.
      -- The book treats this as "by definition" (Etingof p.82).
      sorry
    -- Step 2: S^n End(V) ‚äÜ subalgebra generated by őĒ_n(b) (Lemma 5.18.3 part ii)
    -- Note: diagonalSubalgebra_eq_fullDiagonal requires CharZero k
    have h_full_diag : Lemma5_18_3.fullDiagonalSubalgebra k V n ‚Č§
        Lemma5_18_3.diagonalSubalgebra k V n :=
      (Lemma5_18_3.diagonalSubalgebra_eq_fullDiagonal k V n).ge
    -- Step 3: each őĒ_n(b) generator is in the range of U(gl(V))
    have h_diag_range : Lemma5_18_3.diagonalSubalgebra k V n ‚Č§
        (universalEnvelopingToEnd k V n).range := by
      apply Algebra.adjoin_le
      rintro _ ‚ü®b, rfl‚ü©
      exact (universalEnvelopingToEnd k V n).mem_range.mpr
        ‚ü®UniversalEnvelopingAlgebra.őĻ k b,
          UniversalEnvelopingAlgebra.lift_őĻ_apply k (diagonalLieAction k V n) b‚ü©
    exact (h_cent_full.trans h_full_diag).trans h_diag_range
  ¬∑ -- (‚äá) range ‚Č§ centralizer: image of U(gl(V)) commutes with S_n action
    -- Flip: equivalently, symGroupImage ‚Č§ centralizer(range)
    rw [Subalgebra.le_centralizer_iff]
    -- symGroupImage is adjoin of generators, use adjoin_le
    apply Algebra.adjoin_le
    rintro _ ‚ü®ŌÉ, rfl‚ü©
    rw [SetLike.mem_coe, Subalgebra.mem_centralizer_iff]
    intro x hx
    obtain ‚ü®y, rfl‚ü© := (universalEnvelopingToEnd k V n).mem_range.mp hx
    -- Show: reindex ŌÉ commutes with universalEnvelopingToEnd y
    -- Use hom_ext: conjugation by reindex ŌÉ fixes universalEnvelopingToEnd
    set e := PiTensorProduct.reindex k (fun _ : Fin n => V) ŌÉ
    -- Key: conjAlgEquiv e composed with universalEnvelopingToEnd equals
    -- universalEnvelopingToEnd (they agree on őĻ by the helper lemma)
    have hext : (e.conjAlgEquiv k).toAlgHom.comp
        (universalEnvelopingToEnd k V n) =
        universalEnvelopingToEnd k V n := by
      apply UniversalEnvelopingAlgebra.hom_ext; ext1 b
      simp only [LieHom.comp_apply, AlgHom.toLieHom_apply,
        AlgHom.comp_apply, AlgEquiv.toAlgHom_eq_coe,
        AlgHom.coe_coe, LinearEquiv.conjAlgEquiv_apply,
        universalEnvelopingToEnd,
        UniversalEnvelopingAlgebra.lift_őĻ_apply]
      -- Goal: e ‚ąė‚āó diag b ‚ąė‚āó e.symm = diag b
      -- From helper: diag b * ‚ÜĎe = ‚ÜĎe * diag b (commutation)
      have h := diagonalLieAction_commutes_reindex k V n b ŌÉ
      -- In Module.End mul terms:
      -- (‚ÜĎe * diag b) * ‚ÜĎe.symm = diag b * (‚ÜĎe * ‚ÜĎe.symm) = diag b
      have he_inv : (‚ÜĎe : Module.End k (TnsPow k V n)) *
          ‚ÜĎe.symm = 1 := by
        ext v; simp [Module.End.mul_eq_comp]
      -- conjAlgEquiv e (diag b) = ‚ÜĎe * diag b * ‚ÜĎe.symm
      -- But ‚ąė‚āó is the same as * in Module.End
      change ‚ÜĎe * diagonalLieAction k V n b * ‚ÜĎe.symm =
        diagonalLieAction k V n b
      rw [h.symm, mul_assoc, he_inv, mul_one]
    -- Extract: conjAlgEquiv e (universalEnvelopingToEnd y) =
    --   universalEnvelopingToEnd y
    have key := AlgHom.congr_fun hext y
    simp only [AlgHom.comp_apply, AlgEquiv.toAlgHom_eq_coe,
      AlgHom.coe_coe, LinearEquiv.conjAlgEquiv_apply] at key
    -- key : ‚ÜĎe * universalEnvelopingToEnd y * ‚ÜĎe.symm =
    --        universalEnvelopingToEnd y
    -- Derive commutation: ‚ÜĎe * f = f * ‚ÜĎe
    -- Convert key to * notation: ‚ÜĎe * f * ‚ÜĎe.symm = f
    have key_mul : (‚ÜĎe : Module.End k (TnsPow k V n)) *
        (universalEnvelopingToEnd k V n) y * ‚ÜĎe.symm =
        (universalEnvelopingToEnd k V n) y := by
      simp only [Module.End.mul_eq_comp]; exact key
    have he_inv : (‚ÜĎe.symm : Module.End k (TnsPow k V n)) *
        ‚ÜĎe = 1 := by
      ext v; simp [Module.End.mul_eq_comp]
    -- Multiply key_mul on right by ‚ÜĎe: ‚ÜĎe * f * ‚ÜĎe.symm * ‚ÜĎe = f * ‚ÜĎe
    -- Use assoc: ‚ÜĎe * f * (‚ÜĎe.symm * ‚ÜĎe) = f * ‚ÜĎe, then he_inv
    have := congr_arg (¬∑ * (‚ÜĎe : Module.End k _)) key_mul
    simp only [mul_assoc, he_inv, mul_one] at this
    exact this.symm

end Etingof.Theorem5_18_2
